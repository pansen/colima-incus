PG_DB=vpg
PG_USER=a
PG_PASSWORD=foo

MACHINE_NAME=vpg
MACHINE_MEMORY=12G
MACHINE_CPUS=4

# Logical size of the sparse XFS filesystem that stores both PostgreSQL slots
# and their reflink snapshots. Apple container CLI 1.1 has no configurable
# machine disk-size flag; only blocks actually written to this sparse image
# consume host storage. This is used only at first creation; to grow the store
# later, raise this value and the next `make start` will expand it online via
# xfs_growfs. Shrinking is not supported.
# PG_DATA_DISK_SIZE=140G

# Optional: override the client-facing ports if 5432/5433 already collide with
# something else. Defaults shown.
# PG_ACTIVE_PORT=5432
# PG_STAGING_PORT=5433

# Optional: override the client address printed by status/endpoint. Normally
# the script discovers the Apple machine's eth0 address automatically. This is
# useful only if you route or alias that machine through another stable name.
# PG_MACHINE_IP=

# Optional: pin the backends' static IPs. Defaults are .11/.12 in whatever
# subnet incusbr0 is on (read from `incus network get incusbr0 ipv4.address`).
# The proxy devices dial these addresses directly, so they must stay stable;
# override only if .11/.12 clash with something else in that subnet.
# PG_BACKEND_A_IP=
# PG_BACKEND_B_IP=
