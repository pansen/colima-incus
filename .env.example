PG_DB=vpg
PG_USER=a
PG_PASSWORD=foo

MACHINE_NAME=vpg
MACHINE_MEMORY=12G
MACHINE_CPUS=4

# Logical size of the sparse XFS filesystem that stores both PostgreSQL slots
# and their reflink snapshots. Apple container CLI 1.1 has no configurable
# machine disk-size flag; only blocks actually written to this sparse image
# consume host storage. This is used only at first creation; to grow the store
# later, raise this value and the next `make start` will expand it online via
# xfs_growfs. Shrinking is not supported.
# PG_DATA_DISK_SIZE=140G

# Optional: the machine-side proxy ports the Incus proxy devices listen on
# inside the machine (the forwarder's relay targets). Defaults shown.
# PG_ACTIVE_PORT=5432
# PG_STAGING_PORT=5433

# Optional: the host loopback ports the forwarder listens on, i.e. what local
# clients actually connect to. Offset from 5432/5433 so a local PostgreSQL on
# the default port isn't shadowed on 127.0.0.1. Defaults shown.
# PG_CLIENT_ACTIVE_PORT=5442
# PG_CLIENT_STAGING_PORT=5443

# Optional: the host clients connect to, printed by status/endpoint. Defaults
# to 127.0.0.1, the loopback forwarder installed by `make endpoint.install`.
# To bypass the forwarder, set this to the machine IP and set the client ports
# above back to 5432/5433 (the machine-side ports).
# PG_CLIENT_HOST=127.0.0.1

# Optional: override the discovered machine IP (the forwarder's relay target and
# the address shown as "machine IP"). Normally the script reads the Apple
# machine's eth0 address automatically.
# PG_MACHINE_IP=

# Optional: pin the backends' static IPs. Defaults are .11/.12 in whatever
# subnet incusbr0 is on (read from `incus network get incusbr0 ipv4.address`).
# The proxy devices dial these addresses directly, so they must stay stable;
# override only if .11/.12 clash with something else in that subnet.
# PG_BACKEND_A_IP=
# PG_BACKEND_B_IP=
