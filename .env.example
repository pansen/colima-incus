COLIMA_MEMORY=12
COLIMA_CPU=4

# VM disk size in GiB. Defaults to 140 in the Makefile if unset. colima grows
# an existing disk on restart but never shrinks it, so raising this and
# re-running `make start` enlarges in place. Colima's own default (60 GiB) is
# too small for a multi-GB database plus repeat restores, WAL, and snapshots.
# COLIMA_DISK=140

# Optional: override the client-facing ports if 5432/5433 already collide with
# something else. Defaults shown.
# PG_ACTIVE_PORT=5432
# PG_STAGING_PORT=5433

# Optional: pin the pg-proxy container's static IP — this is the address every
# client connects to.
#
# Default (when this is unset): the script reads
#   incus network get incusbr0 ipv4.address
# and uses .10 inside whatever subnet incusbr0 happens to be on. So with
# a 192.168.100.0/24 bridge you get 192.168.100.10; with a 10.224.165.0/24
# bridge you get 10.224.165.10; etc.
#
# Override here only if you need a specific address (e.g. you already have
# something on .10 in that subnet). The legacy PG_BOUNCER_IP name still works
# as a fallback if you're carrying over an old .env.
# PG_PROXY_IP=

# Optional: pin the backends' static IPs. Defaults are .11/.12 in whatever
# subnet incusbr0 is on (read from `incus network get incusbr0 ipv4.address`).
# The proxy devices dial these addresses directly, so they must stay stable;
# override only if .11/.12 clash with something else in that subnet.
# PG_BACKEND_A_IP=
# PG_BACKEND_B_IP=
