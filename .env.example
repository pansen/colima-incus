PG_PASSWORD=oos4ookahc7si4eejooFee9teePeiqu3quuihuo9Ahhoo7eegh4ohj4fi7gai3vu

# Optional: resource caps applied to each Postgres backend container (pg-dev-a
# and pg-dev-b; the bare pg-proxy keeps Incus defaults). INCUS_MEMORY is in GiB,
# INCUS_CPU is a vCPU count. Applied at `pg.up` and re-asserted (live) on every
# `pg.refresh` / `make start`. Leave blank/unset to inherit Incus defaults.
INCUS_MEMORY=12
INCUS_CPU=6

# Optional: size (GiB) of the shared btrfs storage pool. It holds every
# backend's data + WAL + snapshots at once, so a real dump restore needs plenty
# of headroom (a full pool surfaces as a Postgres crash mid-restore, not a clean
# error). `make start` creates it at this size and grows an existing smaller pool
# up to it (never shrinks). Default: 240.
# POOL_SIZE=240

# Optional: the host IP printed in `make pg.endpoint` / `make pg.ip` and used
# in the .pgpass line. The ports are published on ALL host interfaces
# (listen 0.0.0.0), so any host address reaches them; this just controls which
# one is reported. Default: the source IP of the primary default route.
# PG_HOST_IP=

# Optional: override the host-side ports if 5432/5433 already collide with
# something on the host. Defaults shown.
# PG_ACTIVE_PORT=5432
# PG_STAGING_PORT=5433

# Optional: pin the backends' static IPs. Defaults are .11/.12 in whatever
# subnet incusbr0 is on (read from `incus network get incusbr0 ipv4.address`).
# The proxy forwards dial these addresses, so they must stay stable; override
# only if .11/.12 clash with something else in that subnet.
# PG_BACKEND_A_IP=
# PG_BACKEND_B_IP=
