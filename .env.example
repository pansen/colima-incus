# pgdev configuration. `make` auto-creates .env from this file on first run, so
# copying it by hand is optional — the defaults below (and the commented ones)
# work as-is. Only the PostgreSQL credentials are worth setting.

# PostgreSQL role/database created in each backend (used to build psql/.pgpass
# lines). Change these for anything beyond a throwaway local setup.
PG_DB=vpg
PG_USER=a
PG_PASSWORD=foo

# Instead of putting 127.0.0.1 for the proxy, you can choose whatever you wish
# to be printed in all commands. Using `host.docker.internal` over `127.0.0.1`
# makes things more portable and the database accessible from within other containers
# or k3d.
PG_PROXY_HOSTNAME=host.docker.internal

# Two-machine model (spec 0002): MACHINE_PREFIX yields the per-slot Apple
# machines <prefix>-a / <prefix>-b, each hosting one PostgreSQL backend. CPU and
# memory are PER machine (both share the Mac), so keep memory modest.
MACHINE_PREFIX=vpg
MACHINE_MEMORY=8G
MACHINE_CPUS=4

# Optional: logical size of each machine's sparse XFS snapshot store. Apple 1.1
# has no machine disk-size flag; only blocks actually written consume host
# storage. Used at first creation; raise it and the next `make start` grows it
# online (xfs_growfs). Shrinking is unsupported. Default shown.
# PG_DATA_DISK_SIZE=140G

# Optional: host loopback ports the forwarder listens on — what local clients
# connect to. Offset from 5432 so a local PostgreSQL isn't shadowed. Defaults
# shown. PG_BACKEND_PORT is the port each backend is exposed on (machine eth0).
# PG_CLIENT_ACTIVE_PORT=5442
# PG_CLIENT_STAGING_PORT=5443
# PG_BACKEND_PORT=5432

# Optional: address the host forwarder binds its client listeners to. Default
# 127.0.0.1 (loopback only). Set 0.0.0.0 ONLY if a sibling container/k3d can't
# reach the Mac's loopback — it exposes the dev-credentialed backend on every
# interface (LAN/Wi-Fi), so widen deliberately.
# PG_FORWARD_BIND=127.0.0.1

# Optional: minimum free GiB on the macOS volume before `make pg.up` / restore /
# import will run. The VM disks are sparse images that grow and never shrink, so
# a large restore can fill macOS and shut a guest PostgreSQL store down mid-write.
# Set it to at least the dump size; reclaim with `make pg.staging.rebuild`
# (staging only) or `make recreate` (both). Default shown; see `make disk`.
# DISK_MIN_FREE_GB=40

# Optional: port each in-machine pgdevd daemon serves its HTTP/JSON control API
# on (reached by the host `pgdev` CLI at that machine's IP). Default shown.
# PG_AGENT_PORT=5440
