#!/usr/bin/env bash
set -Eeuo pipefail

# host-endpoint — a stable macOS-side client endpoint for the two Apple
# container machines' PostgreSQL (spec 0002: one machine per slot, vpg-a /
# vpg-b, each exposing its single backend on its own eth0:5432).
#
# The Apple machines' IPs on macOS's internal virtualization bridge are bootpd
# DHCP leases that are NOT pinnable: they (and even their /24) drift across
# macOS reboots and machine recreation, independently per machine. Apple's
# `container machine` CLI exposes no way to fix them (no --network / --publish
# / static IP), and the machines register no resolvable DNS name. So instead of
# chasing the addresses, we publish permanent endpoints on the Mac's loopback
# and relay each to whichever machine currently holds the active/staging role:
#
#   client ── 127.0.0.1:5442 (active)  ──▶ socat ──▶ <active-machine-ip>:5432
#   client ── 127.0.0.1:5443 (staging) ──▶ socat ──▶ <staging-machine-ip>:5432
#
# "Active" vs "staging" is a HOST-side pointer (var/active-machine, "a" or
# "b", default "a" — internal/activeslot on the Go side); `promote` flips it
# and re-runs `refresh` here to re-point which machine backs which client
# port. No data moves and no in-machine proxy is involved.
#
# A per-user launchd LaunchAgent keeps the socat forwarders alive across
# logins. The relay targets are re-resolved on every `make start`/`pgdev
# refresh`/`pgdev promote`.
#
# Unlike the in-machine scripts/pg-dev-local, THIS script runs on macOS.
#
# Usage: host-endpoint {ip|install|refresh|uninstall|status}

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=../.env
[[ -f "$REPO_ROOT/.env" ]] && source "$REPO_ROOT/.env"

# MACHINE_PREFIX yields the per-slot machine names <prefix>-a / <prefix>-b.
# MACHINE_NAME is kept as a fallback for anyone whose .env still only sets the
# legacy single-machine variable.
MACHINE_PREFIX="${MACHINE_PREFIX:-${MACHINE_NAME:-vpg}}"
# Both machines expose their one backend on their own eth0 at this port (no
# in-machine proxy, no separate active/staging port on the guest side).
BACKEND_PORT="${PG_BACKEND_PORT:-5432}"
# Host loopback ports we listen ON — offset from 5432/5433 so a local
# PostgreSQL on the default port isn't shadowed on 127.0.0.1.
CLIENT_ACTIVE_PORT="${PG_CLIENT_ACTIVE_PORT:-5442}"
CLIENT_STAGING_PORT="${PG_CLIENT_STAGING_PORT:-5443}"

LABEL="me.pansen.${MACHINE_PREFIX}-forward"
PLIST="$HOME/Library/LaunchAgents/${LABEL}.plist"
ACTIVE_FILE="$REPO_ROOT/var/active-machine"
IPFILE_A="$REPO_ROOT/var/machine-ip-a"
IPFILE_B="$REPO_ROOT/var/machine-ip-b"
LOGFILE="$REPO_ROOT/var/${MACHINE_PREFIX}-forward.log"
DOMAIN="gui/$(id -u)"

# _machine_name slot → the Apple machine name for that slot ("a"/"b").
_machine_name() { echo "${MACHINE_PREFIX}-$1"; }

# _machine_ip slot → that machine's current eth0 address, discovered live from
# inside the machine. Empty if the machine isn't running. Mirrors
# scripts/pg-dev-local's proxy-IP parsing, per-slot.
_machine_ip() {
    local slot="$1"
    container machine run --name "$(_machine_name "$slot")" --root -- \
        ip -4 -o addr show dev eth0 2>/dev/null \
        | awk '{ split($4, a, "/"); print a[1]; exit }' || true
}

# _active_slot → "a" or "b" (default "a" if the pointer file is absent),
# mirroring internal/activeslot.Pointer.Get on the Go side.
_active_slot() {
    local s
    s="$(cat "$ACTIVE_FILE" 2>/dev/null || true)"
    case "$s" in
        a|b) echo "$s" ;;
        *)   echo "a" ;;
    esac
}

_staging_slot() {
    if [[ "$(_active_slot)" == a ]]; then echo b; else echo a; fi
}

_ip_file() {
    case "$1" in
        a) echo "$IPFILE_A" ;;
        b) echo "$IPFILE_B" ;;
    esac
}

_agent_installed() { [[ -f "$PLIST" ]]; }

_write_plist() {
    # socat lives in a Homebrew prefix that launchd's minimal PATH omits, so we
    # pin its directory into the agent's PATH. If it moves, re-run install.
    local socat_dir
    socat_dir="$(cd "$(dirname "$(command -v socat)")" && pwd)"
    mkdir -p "$(dirname "$PLIST")"
    cat >"$PLIST" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>${LABEL}</string>
    <key>ProgramArguments</key>
    <array>
        <string>${REPO_ROOT}/scripts/host-endpoint</string>
        <string>_serve</string>
    </array>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>${socat_dir}:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>ProcessType</key>
    <string>Background</string>
    <key>StandardOutPath</key>
    <string>${LOGFILE}</string>
    <key>StandardErrorPath</key>
    <string>${LOGFILE}</string>
</dict>
</plist>
EOF
}

# The long-running relay, launched by launchd (never by hand). Reads the
# active-machine pointer and both cached machine IPs, then runs one socat
# listener per role port that is actually resolvable — a missing IP for one
# role (e.g. that machine is down) does not stop the other role's forwarder.
_serve() {
    local active staging active_ip staging_ip
    active="$(_active_slot)"
    staging="$(_staging_slot)"
    active_ip="$(cat "$(_ip_file "$active")" 2>/dev/null || true)"
    staging_ip="$(cat "$(_ip_file "$staging")" 2>/dev/null || true)"

    if [[ -z "$active_ip" && -z "$staging_ip" ]]; then
        echo "$(date '+%F %T') no machine IPs cached; run 'make start'." >&2
        sleep 30   # throttle KeepAlive so we don't hot-loop before the first refresh
        exit 1
    fi

    local -a pids=()
    if [[ -n "$active_ip" ]]; then
        echo "$(date '+%F %T') forwarding 127.0.0.1:${CLIENT_ACTIVE_PORT} -> $(_machine_name "$active") ${active_ip}:${BACKEND_PORT} (active)" >&2
        socat "TCP-LISTEN:${CLIENT_ACTIVE_PORT},bind=127.0.0.1,fork,reuseaddr" "TCP:${active_ip}:${BACKEND_PORT}" &
        pids+=("$!")
    else
        echo "$(date '+%F %T') no IP cached for active machine $(_machine_name "$active"); :${CLIENT_ACTIVE_PORT} not served." >&2
    fi
    if [[ -n "$staging_ip" ]]; then
        echo "$(date '+%F %T') forwarding 127.0.0.1:${CLIENT_STAGING_PORT} -> $(_machine_name "$staging") ${staging_ip}:${BACKEND_PORT} (staging)" >&2
        socat "TCP-LISTEN:${CLIENT_STAGING_PORT},bind=127.0.0.1,fork,reuseaddr" "TCP:${staging_ip}:${BACKEND_PORT}" &
        pids+=("$!")
    else
        echo "$(date '+%F %T') no IP cached for staging machine $(_machine_name "$staging"); :${CLIENT_STAGING_PORT} not served." >&2
    fi

    trap 'kill "${pids[@]}" 2>/dev/null || true' TERM INT
    # Exit (letting KeepAlive restart us) once any started socat dies, or the
    # active/staging pointer flips — either way the target mapping is now
    # stale and a fresh _serve picks up the new one.
    while :; do
        for pid in "${pids[@]}"; do
            kill -0 "$pid" 2>/dev/null || { kill "${pids[@]}" 2>/dev/null || true; exit 1; }
        done
        sleep 5
    done
}

# _refresh_ip_file slot → best-effort refresh of that slot's cached IP file. A
# machine being down is tolerated (its file is just left stale/empty) so a
# staging rebuild or a stopped sibling never blocks refreshing the other.
_refresh_ip_file() {
    local slot="$1" ip
    ip="$(_machine_ip "$slot")"
    if [[ -z "$ip" ]]; then
        echo "WARNING: could not read the IP for $(_machine_name "$slot") (is it running?)." >&2
        return 1
    fi
    mkdir -p "$(dirname "$(_ip_file "$slot")")"
    printf '%s\n' "$ip" >"$(_ip_file "$slot")"
    echo "$ip"
}

_refresh_ip_files() {
    _refresh_ip_file a || true
    _refresh_ip_file b || true
}

_print_endpoints() {
    cat <<EOF
Stable client endpoints (127.0.0.1 is permanent; the forwarder tracks each machine's IP and follows 'promote'):
  active   ($(_machine_name "$(_active_slot)"))  psql -h 127.0.0.1 -p ${CLIENT_ACTIVE_PORT}  -U ${PG_USER:-<user>} ${PG_DB:-<db>}
  staging  ($(_machine_name "$(_staging_slot)"))  psql -h 127.0.0.1 -p ${CLIENT_STAGING_PORT} -U ${PG_USER:-<user>} ${PG_DB:-<db>}

.pgpass lines:
127.0.0.1:${CLIENT_ACTIVE_PORT}:*:${PG_USER:-<user>}:${PG_PASSWORD:-<password>}
127.0.0.1:${CLIENT_STAGING_PORT}:*:${PG_USER:-<user>}:${PG_PASSWORD:-<password>}
EOF
}

cmd_ip() { _machine_ip a; echo; _machine_ip b; }

cmd_install() {
    _refresh_ip_files
    _write_plist
    launchctl bootout "$DOMAIN/$LABEL" 2>/dev/null || true
    if ! launchctl bootstrap "$DOMAIN" "$PLIST"; then
        echo "ERROR: launchctl bootstrap failed for $LABEL." >&2
        return 1
    fi
    launchctl kickstart -k "$DOMAIN/$LABEL" 2>/dev/null || true
    echo "==> Forwarder '$LABEL' installed."
    _print_endpoints
}

cmd_refresh() {
    # Called from every `make start` and `pgdev promote`/`refresh`. First time
    # (no agent yet) it installs itself so the forwarder is fully hands-off;
    # afterwards it just re-points (re-reading the active pointer, so a
    # promote is picked up here too). Opt out with PG_ENDPOINT_AUTOINSTALL=0
    # to keep a deliberate uninstall.
    if ! _agent_installed; then
        if [[ "${PG_ENDPOINT_AUTOINSTALL:-1}" == 0 ]]; then
            echo "==> Endpoint forwarder not installed; skipping (PG_ENDPOINT_AUTOINSTALL=0)."
            return 0
        fi
        echo "==> Endpoint forwarder not installed; installing it now..."
        cmd_install || echo "WARNING: auto-install failed; run 'make endpoint.install' manually." >&2
        return 0   # never fail 'make start' on the endpoint step
    fi
    _refresh_ip_files || true   # tolerate: don't fail 'make start' if a machine is down
    launchctl kickstart -k "$DOMAIN/$LABEL" 2>/dev/null \
        || { launchctl bootstrap "$DOMAIN" "$PLIST" 2>/dev/null || true; }
    echo "==> Forwarder re-pointed: active=$(_machine_name "$(_active_slot)") staging=$(_machine_name "$(_staging_slot)") (endpoints stay 127.0.0.1:${CLIENT_ACTIVE_PORT}/:${CLIENT_STAGING_PORT})."
}

cmd_uninstall() {
    launchctl bootout "$DOMAIN/$LABEL" 2>/dev/null || true
    rm -f "$PLIST"
    echo "==> Forwarder '$LABEL' removed."
}

cmd_status() {
    if _agent_installed; then
        echo "plist:          $PLIST"
        echo "active machine: $(_machine_name "$(_active_slot)")"
        echo "cached IP a:    $(cat "$IPFILE_A" 2>/dev/null || echo '(none)')"
        echo "cached IP b:    $(cat "$IPFILE_B" 2>/dev/null || echo '(none)')"
        echo "live IP a:      $(_machine_ip a || true)"
        echo "live IP b:      $(_machine_ip b || true)"
        launchctl print "$DOMAIN/$LABEL" 2>/dev/null | grep -E 'state =|pid =' || \
            echo "launchd:        not loaded"
    else
        echo "Forwarder not installed. Run 'make endpoint.install'."
    fi
}

case "${1:-}" in
    ip)        cmd_ip ;;
    install)   cmd_install ;;
    refresh)   cmd_refresh ;;
    uninstall) cmd_uninstall ;;
    status)    cmd_status ;;
    _serve)    _serve ;;
    *) echo "Usage: host-endpoint {ip|install|refresh|uninstall|status}" >&2; exit 2 ;;
esac
