#!/usr/bin/env bash
set -euo pipefail

# Guest stdin from an Apple `machine run --interactive` session is a pipe
# (not a TTY) that the host holds open for the session's lifetime. incus
# `storage create` / `network create` read YAML config from any non-TTY
# stdin until EOF, so they block forever on it. This bootstrap is strictly
# non-interactive: detach stdin so those reads hit EOF immediately.
exec </dev/null

# Idempotent bootstrap for the persistent Apple container machine. The stock
# Apple kernel has XFS and loop devices built in, but lacks the Btrfs, ZFS, and
# DM-thin stack used by Incus's optimized snapshot backends. A sparse XFS loop
# filesystem therefore supplies CoW reflinks for the PostgreSQL data timelines
# while Incus uses `dir` for the comparatively small container root filesystems.

DATA_IMAGE=/var/lib/pg-dev-local.xfs
DATA_ROOT=/var/lib/pg-dev-local
DATA_SIZE=${PG_DATA_DISK_SIZE:-140G}
FSTAB_ENTRY="$DATA_IMAGE $DATA_ROOT xfs loop,nofail 0 0"
image_tmp=
loop_device=

# `container machine run` can accept a command a few hundred milliseconds
# after PID 1 starts, before systemd's private/system bus is listening.
# `systemctl show --property=Version` succeeds against /run/systemd/private
# as soon as the manager forks, which is *before* the system D-Bus bus is up,
# so it does not actually close the race. `systemctl is-system-running
# --wait` blocks until the boot transaction has fully settled -- which
# includes dbus.socket -- but only once it can reach the bus at all: if the
# exec session lands before the bus socket exists, it fails instantly with
# "Failed to connect to system scope bus" instead of waiting. Retry until
# the bus answers (empty output = connect failure), then trust --wait.
if [[ "$(ps -p 1 -o comm= | xargs)" != systemd ]]; then
    echo "ERROR: PID 1 is not systemd; refusing to continue." >&2
    echo "       PID 1: $(ps -p 1 -o comm=,args= 2>/dev/null || echo unavailable)" >&2
    exit 1
fi
system_state=$(timeout 90 bash -c '
    while :; do
        state=$(systemctl is-system-running --wait 2>/dev/null || true)
        if [[ -n "$state" ]]; then
            printf "%s" "$state"
            exit 0
        fi
        sleep 1
    done' || true)
# "degraded" is the permanent steady state here: Apple's guest kernel has no
# loadable-module support, so systemd-modules-load.service always fails with
# "Failed to initialize libkmod context: Operation not supported" and holds
# the system at "degraded" forever. Treat running/degraded as ready; anything
# else (including an empty result from a 90s timeout) is a hard failure.
if [[ "$system_state" != running && "$system_state" != degraded ]]; then
    echo "ERROR: systemd did not settle within 90 seconds (state: ${system_state:-timeout})." >&2
    systemctl is-system-running >&2 || true
    systemctl --failed --no-legend >&2 || true
    exit 1
fi

_bootstrap_cleanup() {
    local status="$?"
    trap - EXIT
    set +e
    if [[ -n "$loop_device" ]]; then
        losetup --detach "$loop_device"
    fi
    if [[ -n "$image_tmp" ]]; then
        rm -f -- "$image_tmp"
    fi
    exit "$status"
}

trap _bootstrap_cleanup EXIT
trap 'exit 129' HUP
trap 'exit 130' INT
trap 'exit 143' TERM

if ! command -v incus >/dev/null 2>&1 \
    || ! command -v dnsmasq >/dev/null 2>&1 \
    || ! command -v mkfs.xfs >/dev/null 2>&1 \
    || ! command -v jq >/dev/null 2>&1; then
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -q
    apt-get install -y --no-install-recommends dnsmasq-base incus-base jq xfsprogs
fi

systemctl enable --now incus.socket incus.service

# incusd's first start (cert generation, database init, kernel feature
# probing) can lag well behind the systemd start job, and the incus CLI
# blocks silently on the unix socket until the daemon answers. Wait for
# readiness with a bound so a wedged daemon fails loudly instead of
# hanging the bootstrap.
if ! incus admin waitready --timeout 90; then
    echo "ERROR: incusd did not become ready within 90 seconds." >&2
    systemctl status incus.service --no-pager >&2 || true
    journalctl -u incus.service --no-pager -n 50 >&2 || true
    exit 1
fi

if [[ ! -e "$DATA_IMAGE" ]]; then
    echo "==> Creating sparse $DATA_SIZE XFS data store at $DATA_IMAGE..."
    image_tmp="${DATA_IMAGE}.creating.$$"
    loop_device=
    rm -f "$image_tmp"
    truncate -s "$DATA_SIZE" "$image_tmp"
    loop_device=$(losetup --find --show "$image_tmp")
    if mkfs.xfs -m reflink=1 "$loop_device"; then
        losetup --detach "$loop_device"
        loop_device=
        mv "$image_tmp" "$DATA_IMAGE"
        image_tmp=
    else
        result=$?
        losetup --detach "$loop_device" 2>/dev/null || true
        loop_device=
        rm -f "$image_tmp"
        image_tmp=
        exit "$result"
    fi
fi

echo "==> Mounting and verifying $DATA_ROOT..."
mkdir -p "$DATA_ROOT"
if ! grep -Fqx "$FSTAB_ENTRY" /etc/fstab; then
    printf '%s\n' "$FSTAB_ENTRY" >> /etc/fstab
fi
if ! mountpoint -q "$DATA_ROOT"; then
    loop_device=$(losetup --find --show --read-only "$DATA_IMAGE")
    image_type=$(blkid --probe --output value --match-tag TYPE "$loop_device" 2>/dev/null || true)
    losetup --detach "$loop_device"
    loop_device=
    if [[ "$image_type" != xfs ]]; then
        echo "ERROR: existing $DATA_IMAGE is not a valid XFS filesystem; refusing to overwrite it." >&2
        exit 1
    fi
    mount "$DATA_ROOT"
fi

if ! xfs_info "$DATA_ROOT" | grep -q 'reflink=1'; then
    echo "ERROR: $DATA_ROOT is not an XFS filesystem with reflinks enabled." >&2
    exit 1
fi

# Fail early if the running kernel/filesystem cannot actually perform the CoW
# operation that the database snapshot implementation relies on.
probe_source="$DATA_ROOT/.reflink-probe-source"
probe_copy="$DATA_ROOT/.reflink-probe-copy"
printf 'reflink probe\n' > "$probe_source"
if ! cp --reflink=always "$probe_source" "$probe_copy"; then
    rm -f "$probe_source" "$probe_copy"
    echo "ERROR: XFS reflink copies are unavailable on $DATA_ROOT." >&2
    exit 1
fi
rm -f "$probe_source" "$probe_copy"

# PG_DATA_DISK_SIZE was only consulted above when the image didn't exist yet,
# so raising it after the first boot would otherwise be silently ignored.
# Grow the backing image and the XFS filesystem in place when it has been
# raised; shrinking a live XFS filesystem isn't supported, so just warn.
requested_bytes=$(numfmt --from=iec "$DATA_SIZE" 2>/dev/null || true)
if [[ -z "$requested_bytes" ]]; then
    echo "WARNING: could not parse PG_DATA_DISK_SIZE=$DATA_SIZE; skipping resize check." >&2
else
    current_bytes=$(stat -c %s "$DATA_IMAGE")
    if (( requested_bytes > current_bytes )); then
        echo "==> Growing data store to $DATA_SIZE..."
        df_before=$(df --output=size "$DATA_ROOT" | tail -n1 | xargs)
        truncate -s "$DATA_SIZE" "$DATA_IMAGE"
        grow_loop_device=$(losetup -j "$DATA_IMAGE" | cut -d: -f1 | head -n1)
        if [[ -z "$grow_loop_device" ]]; then
            echo "ERROR: could not find the loop device backing $DATA_IMAGE." >&2
            exit 1
        fi
        losetup -c "$grow_loop_device"
        xfs_growfs "$DATA_ROOT" >/dev/null
        df_after=$(df --output=size "$DATA_ROOT" | tail -n1 | xargs)
        if (( df_after <= df_before )); then
            echo "ERROR: $DATA_ROOT did not grow after xfs_growfs (before: ${df_before}, after: ${df_after})." >&2
            exit 1
        fi
        echo "PostgreSQL data store grown: $DATA_ROOT ($(df -h --output=size,used,avail "$DATA_ROOT" | tail -n1 | xargs))"
    elif (( requested_bytes < current_bytes )); then
        echo "WARNING: PG_DATA_DISK_SIZE=$DATA_SIZE is smaller than the current data store; shrinking is unsupported, staying at the current size." >&2
    fi
fi

echo "==> Configuring Incus storage, network, and profile..."
# A freshly installed daemon has no pool/network/profile devices. Configure
# those once without disturbing an already initialized experimental machine.
if ! incus storage list --format csv -c n 2>/dev/null | grep -qx default; then
    incus storage create default dir
fi
if ! incus network list --format csv -c n 2>/dev/null | grep -qx incusbr0; then
    incus network create incusbr0 \
        ipv4.address=auto ipv4.nat=true \
        ipv6.address=auto ipv6.nat=true
fi
if ! incus profile device get default root path >/dev/null 2>&1; then
    incus profile device add default root disk path=/ pool=default
fi
if ! incus profile device get default eth0 network >/dev/null 2>&1; then
    incus profile device add default eth0 nic network=incusbr0 name=eth0
fi

mkdir -p "$DATA_ROOT/a/current" "$DATA_ROOT/a/snapshots"
mkdir -p "$DATA_ROOT/b/current" "$DATA_ROOT/b/snapshots"

echo "Apple machine ready: Incus $(incus version | awk '/Server version/ { print $3 }')"
echo "PostgreSQL data store: $DATA_ROOT ($(df -h --output=size,used,avail "$DATA_ROOT" | tail -n1 | xargs))"
