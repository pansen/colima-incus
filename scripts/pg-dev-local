#!/usr/bin/env bash
set -euo pipefail
# set -x

# pg-dev-local — two PostgreSQL backends behind a dual-listener pgbouncer.
# See README.md's Design section for the rationale.
#
#   pg-dev-a, pg-dev-b   long-lived backends with their own snapshot timelines
#   pg-bouncer           one container carrying both access paths:
#                          :5432  active  direct proxy  (pooler-free)
#                          :5433  staging direct proxy  (pooler-free)
#                          :5442  active  pgbouncer     (session pool)
#                          :5443  staging pgbouncer     (session pool)
#                        cross-connect enforced by rendering both inis from
#                        one state file (var/active-slot).

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=../.env
[[ -f "$REPO_ROOT/.env" ]] && source "$REPO_ROOT/.env"

PG_USER="${PG_USER:?PG_USER must be set in .env}"
PG_DB="${PG_DB:?PG_DB must be set in .env}"
PG_PASSWORD="${PG_PASSWORD:?PG_PASSWORD must be set in .env}"

# Same secret for the bouncer admin user. Dev convenience: one .pgpass line
# covers everything. README.md's Design section says this loudly.
PG_BOUNCER_ADMIN_PASSWORD="$PG_PASSWORD"

IMAGE=images:ubuntu/24.04/cloud
BACKEND_PREFIX=pg-dev
BACKEND_A="${BACKEND_PREFIX}-a"
BACKEND_B="${BACKEND_PREFIX}-b"
BOUNCER=pg-bouncer
STATE_DIR="$REPO_ROOT/var"
STATE_FILE="$STATE_DIR/active-slot"

# Client-facing ports. The primary ports (:5432 active, :5433 staging) are
# pooler-free *direct* lines — incus `proxy` devices on the bouncer that relay
# a raw TCP connection straight to the backend's Postgres, no pgbouncer in the
# path. They follow promote (we re-point each device's `connect` when active
# flips) and carry no session stickiness: a client disconnect tears down the
# backend connection, so "DROP DATABASE" in test teardown succeeds instead of
# failing with ObjectInUse, and a bulk `pg_restore` isn't funneled through the
# single-threaded pooler. pgbouncer moves up to the 544x range for callers that
# still want session pooling (:5442 active, :5443 staging).
ACTIVE_PORT="${PG_ACTIVE_PORT:-5432}"            # direct proxy → active backend
STAGING_PORT="${PG_STAGING_PORT:-5433}"          # direct proxy → staging backend
BOUNCER_ACTIVE_PORT="${PG_BOUNCER_ACTIVE_PORT:-5442}"
BOUNCER_STAGING_PORT="${PG_BOUNCER_STAGING_PORT:-5443}"

# The two direct-forward proxy devices on the bouncer (active + staging).
DIRECT_ACTIVE_DEVICE=pgdirect-active
DIRECT_STAGING_DEVICE=pgdirect-staging
LEGACY_DIRECT_DEVICE=pgdirect                    # pre-migration single :5434 device

# How long promote lets PAUSE drain cleanly before forcing the swap with KILL.
# PAUSE only *returns* once every server is released; in session pooling an
# idle-but-connected client never releases on its own, so a bare PAUSE hangs
# forever. See _promote_drain.
PROMOTE_PAUSE_TIMEOUT="${PROMOTE_PAUSE_TIMEOUT:-10}"

# ---------------------------------------------------------------------------
# State helpers
# ---------------------------------------------------------------------------

_active()    { cat "$STATE_FILE" 2>/dev/null || echo a; }
_staging()   { [[ "$(_active)" == a ]] && echo b || echo a; }
_c_active()  { echo "${BACKEND_PREFIX}-$(_active)"; }
_c_staging() { echo "${BACKEND_PREFIX}-$(_staging)"; }

_set_active() {
    local new="$1"
    mkdir -p "$STATE_DIR"
    local tmp
    tmp="$(mktemp "$STATE_FILE.XXXXXX")"
    printf '%s\n' "$new" > "$tmp"
    mv "$tmp" "$STATE_FILE"
}

# ---------------------------------------------------------------------------
# Bouncer helpers
# ---------------------------------------------------------------------------

_bouncer_ip() {
    # Empty if pg-bouncer has no IPv4 (e.g. it's stopped). `|| true` so
    # pipefail doesn't trip on grep finding nothing.
    incus list "$BOUNCER" --format csv -c 4 2>/dev/null \
        | grep -oE '[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+' \
        | head -1 || true
}

# RUNNING / STOPPED / FROZEN / … — empty if the container doesn't exist.
_state() {
    incus list "$1" --format csv -c s 2>/dev/null | head -n1 || true
}

# The /24 prefix of incusbr0, e.g. "10.224.165" from "10.224.165.1/24".
_incusbr0_prefix() {
    local addr
    addr=$(incus network get incusbr0 ipv4.address 2>/dev/null || true)
    if [[ -z "$addr" || "$addr" == "none" ]]; then
        echo "ERROR: cannot read incusbr0 ipv4.address; set the IPs explicitly in .env" >&2
        exit 1
    fi
    local prefix=${addr%.*}
    echo "${prefix%%/*}"
}

# Derive a stable IP for the bouncer in the incusbr0 subnet (e.g. 10.x.x.10),
# unless PG_BOUNCER_IP is set in .env.
_pick_bouncer_ip() {
    if [[ -n "${PG_BOUNCER_IP:-}" ]]; then
        echo "$PG_BOUNCER_IP"
        return
    fi
    echo "$(_incusbr0_prefix).10"
}

# Static IPs for the backends. Like the bouncer, the backends MUST keep a
# stable address: pgbouncer reaches them by container name (host=pg-dev-a),
# which Incus resolves from a dnsmasq DNS record built off the DHCP lease.
# Dynamic leases — and thus those A records — are wiped on a VM reboot,
# leaving pgbouncer unable to resolve the backend and every client stalled.
# A pinned ipv4.address yields a STATIC lease that Incus regenerates on
# daemon start, so the record survives. Override in .env if .11/.12 clash.
_pick_backend_a_ip() { echo "${PG_BACKEND_A_IP:-$(_incusbr0_prefix).11}"; }
_pick_backend_b_ip() { echo "${PG_BACKEND_B_IP:-$(_incusbr0_prefix).12}"; }

# The current IPv4 of a container, or empty if it has none / doesn't exist.
_container_ip() {
    incus list "$1" --format csv -c 4 2>/dev/null \
        | grep -oE '[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+' \
        | head -1 || true
}

# _repair_backend_ip <container> <wanted-ip>
# Make sure <container> owns the pinned static IP <wanted-ip> and that the
# bouncer resolves its name to it. This is the self-heal for backends that
# predate IP pinning (their eth0 is unpinned, so they hold a DYNAMIC lease
# whose DNS record c-ares resolves only intermittently → clients stall) or
# whose lease has otherwise drifted. Fully idempotent: when everything is
# already correct it touches nothing, so it's safe on every bouncer.reload.
_repair_backend_ip() {
    local container="$1" want="$2"
    [[ -z "$want" ]] && return 0
    incus info "$container" >/dev/null 2>&1 || return 0   # not provisioned yet

    # 1) Pin the device address if it's missing or wrong. `override` creates
    #    the local device over the profile-inherited NIC; once it's already
    #    local, `override` fails and `set` is the right verb.
    local have
    have=$(incus config device get "$container" eth0 ipv4.address 2>/dev/null || true)
    if [[ "$have" != "$want" ]]; then
        echo "==> Pinning $container eth0 → $want (was ${have:-unset})..."
        incus config device override "$container" eth0 ipv4.address="$want" 2>/dev/null \
            || incus config device set "$container" eth0 ipv4.address="$want"
    fi

    # 2) A running backend on the wrong address needs a restart for the new
    #    static lease to take hold; a stopped one picks it up on next start.
    if [[ "$(_state "$container")" == "RUNNING" && "$(_container_ip "$container")" != "$want" ]]; then
        echo "==> Restarting $container to apply $want..."
        incus restart "$container"
        until [[ "$(_container_ip "$container")" == "$want" ]]; do sleep 1; done
    fi

    # 3) Keep an /etc/hosts entry in the bouncer in lockstep with the pin.
    #    pgbouncer's c-ares resolver is flaky against the dual A/AAAA records
    #    served by the systemd-resolved stub; a hosts entry makes resolution
    #    deterministic and IPv4-only, and a static pin keeps it from staling.
    if [[ "$(_state "$BOUNCER")" == "RUNNING" ]]; then
        incus exec "$BOUNCER" -- bash -c "
            sed -i '/[[:space:]]${container}\$/d' /etc/hosts
            echo '${want} ${container}' >> /etc/hosts
        "
    fi
}

# _bouncer_admin <role: active|staging> <SQL...>
# Admin access is the special `pgbouncer` virtual database on the same
# listen_port as data — pgbouncer doesn't expose a separate admin port.
_bouncer_admin() {
    local role="$1"; shift
    local port
    case "$role" in
        active)  port=$BOUNCER_ACTIVE_PORT ;;
        staging) port=$BOUNCER_STAGING_PORT ;;
        *) echo "bad role: $role" >&2; exit 1 ;;
    esac
    incus exec "$BOUNCER" -- env PGPASSWORD="$PG_BOUNCER_ADMIN_PASSWORD" \
        psql -h 127.0.0.1 -p "$port" -U pgb_admin -d pgbouncer -c "$*"
}

# _render_ini <role: active|staging> <listen_port> <backend container name>
_render_ini() {
    local role="$1" port="$2" backend="$3"
    incus exec "$BOUNCER" -- tee "/etc/pgbouncer/${role}.ini" > /dev/null <<EOF
;; rendered by pg-dev-local — do not edit by hand
[databases]
${PG_DB} = host=${backend} dbname=${PG_DB}
* = host=${backend}

[pgbouncer]
listen_addr = *
listen_port = ${port}
unix_socket_dir = /var/run/pgbouncer-${role}
auth_type = scram-sha-256
auth_file = /etc/pgbouncer/userlist.txt
admin_users = pgb_admin
stats_users = pgb_admin
pool_mode = session
server_reset_query = DISCARD ALL
ignore_startup_parameters = extra_float_digits,statement_timeout,lock_timeout,idle_in_transaction_session_timeout,search_path,default_transaction_isolation,default_transaction_read_only,default_transaction_deferrable
logfile = /var/log/pgbouncer/${role}.log
pidfile = /var/run/pgbouncer/${role}.pid
EOF
}

# The pinned IP of whichever backend is currently active / staging.
_active_backend_ip() {
    if [[ "$(_active)" == a ]]; then _pick_backend_a_ip; else _pick_backend_b_ip; fi
}
_staging_backend_ip() {
    if [[ "$(_staging)" == a ]]; then _pick_backend_a_ip; else _pick_backend_b_ip; fi
}

# Add-or-re-point one direct-forward proxy device (a raw TCP relay in the
# bouncer's network namespace) toward a backend's Postgres. Idempotent: creates
# the device once, then just re-points `connect` on later calls.
_set_direct_device() {
    local device="$1" listen_port="$2" ip="$3"
    if incus config device get "$BOUNCER" "$device" connect >/dev/null 2>&1; then
        incus config device set "$BOUNCER" "$device" connect="tcp:${ip}:5432"
    else
        echo "==> Adding direct-forward proxy $BOUNCER:$listen_port → ${ip}:5432..."
        incus config device add "$BOUNCER" "$device" proxy \
            listen="tcp:0.0.0.0:${listen_port}" connect="tcp:${ip}:5432" bind=instance >/dev/null
    fi
}

# Ensure both direct-forward proxies exist and point at the right backends:
# :5432 → active, :5433 → staging. Re-pointed on promote / bouncer.reload / VM
# boot. A no-op when the bouncer isn't running.
#
# These bind the primary ports *inside* the bouncer's netns, so pgbouncer must
# already have vacated them (it listens on :5442/:5443). Fresh provisioning
# renders the bouncer inis on those ports before first start; a live migration
# from the old scheme goes through cmd_bouncer_reload, which restarts pgbouncer
# onto the new ports first.
_set_direct_forward() {
    [[ "$(_state "$BOUNCER")" == "RUNNING" ]] || return 0
    _set_direct_device "$DIRECT_ACTIVE_DEVICE"  "$ACTIVE_PORT"  "$(_active_backend_ip)"
    _set_direct_device "$DIRECT_STAGING_DEVICE" "$STAGING_PORT" "$(_staging_backend_ip)"
}

# ---------------------------------------------------------------------------
# Provisioning
# ---------------------------------------------------------------------------

_provision_backend() {
    local container="$1" ip="$2"

    echo "==> Launching $container..."
    incus launch --verbose "$IMAGE" "$container"

    echo "==> Waiting for IPv4 on $container..."
    until incus list "$container" --format csv -c 4 | grep -qE '[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+'; do
        sleep 2
    done

    echo "==> Pinning $container eth0 → $ip (static lease → durable DNS record)..."
    incus config device override "$container" eth0 ipv4.address="$ip"
    incus restart "$container"
    until incus list "$container" --format csv -c 4 | grep -q "$ip"; do
        sleep 1
    done

    echo "==> Installing PostgreSQL 17 on $container..."
    incus exec --verbose "$container" -- bash <<'SETUP'
set -euo pipefail
export DEBIAN_FRONTEND=noninteractive

apt-get update -q
apt-get install -y curl gnupg lsb-release

curl -fsSL https://www.postgresql.org/media/keys/ACCC4CF8.asc \
    | gpg --dearmor -o /etc/apt/trusted.gpg.d/pgdg.gpg
echo "deb https://apt.postgresql.org/pub/repos/apt $(lsb_release -cs)-pgdg main" \
    > /etc/apt/sources.list.d/pgdg.list
apt-get update -q
apt-get install -y --no-install-recommends postgresql-17

mkdir -p /etc/postgresql/17/main/conf.d
cat > /etc/postgresql/17/main/conf.d/99-dev.conf <<'PGCONF'
listen_addresses = '*'
dynamic_shared_memory_type = posix

shared_buffers = 2GB
effective_cache_size = 6GB
work_mem = 32MB
maintenance_work_mem = 1GB
max_parallel_maintenance_workers = 4

max_wal_size = 16GB
checkpoint_timeout = 30min
checkpoint_completion_target = 0.8
wal_level = minimal
max_wal_senders = 0

fsync = off
full_page_writes = off
synchronous_commit = off
autovacuum = off

log_destination = stderr
logging_collector = off
log_min_duration_statement = 0
log_checkpoints = on
log_lock_waits = on
deadlock_timeout = 100
debug_pretty_print = on
PGCONF

cat > /etc/postgresql/17/main/pg_hba.conf <<'PGHBA'
local   all   postgres                peer
local   all   all                     md5
host    all   all   0.0.0.0/0         scram-sha-256
host    all   all   ::/0              scram-sha-256
PGHBA

systemctl restart postgresql@17-main
SETUP

    echo "==> Creating role '$PG_USER' and database '$PG_DB' on $container..."
    incus exec --verbose "$container" -- su -c psql postgres <<SQL
CREATE ROLE "$PG_USER" WITH LOGIN PASSWORD '$PG_PASSWORD' SUPERUSER;
CREATE DATABASE "$PG_DB" OWNER "$PG_USER";
SQL

    echo "==> Snapshotting $container @ initial..."
    incus pause "$container"
    incus snapshot create "$container" initial
    incus resume "$container"
}

_provision_bouncer() {
    local bouncer_ip="$1"

    echo "==> Launching $BOUNCER..."
    incus launch --verbose "$IMAGE" "$BOUNCER"

    echo "==> Waiting for IPv4 on $BOUNCER..."
    until incus list "$BOUNCER" --format csv -c 4 | grep -qE '[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+'; do
        sleep 2
    done

    echo "==> Pinning $BOUNCER eth0 → $bouncer_ip..."
    incus config device override "$BOUNCER" eth0 ipv4.address="$bouncer_ip"
    incus restart "$BOUNCER"
    until incus list "$BOUNCER" --format csv -c 4 | grep -q "$bouncer_ip"; do
        sleep 1
    done

    echo "==> Installing pgbouncer + psql client on $BOUNCER..."
    incus exec --verbose "$BOUNCER" -- bash <<'SETUP'
set -euo pipefail
export DEBIAN_FRONTEND=noninteractive

apt-get update -q
apt-get install -y --no-install-recommends pgbouncer postgresql-client

# The Debian package ships a single-instance unit. We replace it with a
# template so we can run active and staging side by side.
systemctl disable --now pgbouncer.service 2>/dev/null || true

# /var/run is tmpfs and wiped on every boot, so a one-time mkdir wouldn't
# survive a container/VM restart — pgbouncer would then fail to create its
# unix socket and exit. Declare the socket/pid dirs via tmpfiles.d so systemd
# recreates them on every boot. /var/log is persistent, so a mkdir is fine.
cat > /etc/tmpfiles.d/pgbouncer-dev.conf <<'TMPFILES'
d /run/pgbouncer          0755 postgres postgres -
d /run/pgbouncer-active   0755 postgres postgres -
d /run/pgbouncer-staging  0755 postgres postgres -
TMPFILES
systemd-tmpfiles --create /etc/tmpfiles.d/pgbouncer-dev.conf

mkdir -p /var/log/pgbouncer
chown postgres:postgres /var/log/pgbouncer

cat > /etc/systemd/system/pgbouncer@.service <<'UNIT'
[Unit]
Description=pgbouncer (%i instance)
After=network.target

[Service]
Type=simple
User=postgres
Group=postgres
ExecStart=/usr/sbin/pgbouncer /etc/pgbouncer/%i.ini
Restart=on-failure
RestartSec=1

[Install]
WantedBy=multi-user.target
UNIT

systemctl daemon-reload
SETUP

    echo "==> Writing userlist.txt..."
    incus exec "$BOUNCER" -- tee /etc/pgbouncer/userlist.txt > /dev/null <<EOF
"$PG_USER" "$PG_PASSWORD"
"pgb_admin" "$PG_BOUNCER_ADMIN_PASSWORD"
EOF
    incus exec "$BOUNCER" -- chown postgres:postgres /etc/pgbouncer/userlist.txt
    incus exec "$BOUNCER" -- chmod 640 /etc/pgbouncer/userlist.txt

    echo "==> Rendering pgbouncer inis (active→$BACKEND_A, staging→$BACKEND_B)..."
    _render_ini active  "$BOUNCER_ACTIVE_PORT"  "$BACKEND_A"
    _render_ini staging "$BOUNCER_STAGING_PORT" "$BACKEND_B"

    echo "==> Enabling and starting pgbouncer@{active,staging}..."
    incus exec "$BOUNCER" -- systemctl enable --now \
        pgbouncer@active pgbouncer@staging

    # Tiny readiness probe.
    local tries=0
    until _bouncer_admin active "SHOW VERSION;" >/dev/null 2>&1; do
        tries=$((tries + 1))
        if (( tries > 20 )); then
            echo "ERROR: pgbouncer@active not responding on :$BOUNCER_ACTIVE_PORT" >&2
            incus exec "$BOUNCER" -- journalctl -u pgbouncer@active --no-pager | tail -n 40 >&2
            exit 1
        fi
        sleep 1
    done
    tries=0
    until _bouncer_admin staging "SHOW VERSION;" >/dev/null 2>&1; do
        tries=$((tries + 1))
        if (( tries > 20 )); then
            echo "ERROR: pgbouncer@staging not responding on :$BOUNCER_STAGING_PORT" >&2
            incus exec "$BOUNCER" -- journalctl -u pgbouncer@staging --no-pager | tail -n 40 >&2
            exit 1
        fi
        sleep 1
    done
}

# ---------------------------------------------------------------------------
# Lifecycle commands
# ---------------------------------------------------------------------------

cmd_up() {
    if incus info pg-dev > /dev/null 2>&1; then
        cat <<MSG
NOTE: a legacy 'pg-dev' container exists alongside this setup. It won't
conflict — the new system uses pg-dev-a, pg-dev-b, pg-bouncer — but it
will sit there using disk/memory until you delete it:

    incus delete pg-dev --force

Continuing in 1s...
MSG
        sleep 1
    fi

    for c in "$BACKEND_A" "$BACKEND_B" "$BOUNCER"; do
        if incus info "$c" > /dev/null 2>&1; then
            echo "Container '$c' already exists — run '$0 down' first."
            exit 1
        fi
    done

    local bouncer_ip backend_a_ip backend_b_ip
    bouncer_ip=$(_pick_bouncer_ip)
    backend_a_ip=$(_pick_backend_a_ip)
    backend_b_ip=$(_pick_backend_b_ip)
    echo "==> Static IPs: $BACKEND_A=$backend_a_ip  $BACKEND_B=$backend_b_ip  $BOUNCER=$bouncer_ip"

    _provision_backend "$BACKEND_A" "$backend_a_ip"
    _provision_backend "$BACKEND_B" "$backend_b_ip"
    _provision_bouncer "$bouncer_ip"

    _set_active a
    _set_direct_forward

    echo
    echo "==> pg-dev ready."
    echo
    cmd_endpoint
}

cmd_down() {
    for c in "$BOUNCER" "$BACKEND_A" "$BACKEND_B"; do
        incus delete "$c" --force 2>/dev/null || true
    done
    rm -f "$STATE_FILE"
}

# Box-table renderer for cmd_status. Reads rows on stdin; columns are separated
# by US (\037) and multi-line cells split on RS (\036). The first row is the
# header (centered); data cells are left-aligned. Mirrors incus's own table
# look (a border after every row) so the two outputs sit together naturally.
_render_table() {
    awk -v FSU=$'\037' -v SUB=$'\036' '
    function rep(ch, n,   s) { s = ""; while (n-- > 0) s = s ch; return s }
    function bord(   c, s) { s = "+"; for (c = 1; c <= ncol; c++) s = s rep("-", w[c] + 2) "+"; return s }
    function ctr(str, width,   t, l) { t = width - length(str); l = int(t / 2); return rep(" ", l) str rep(" ", t - l) }
    function prow(r,   i, c, val, line) {
        for (i = 1; i <= ht[r]; i++) {
            line = "|"
            for (c = 1; c <= ncol; c++) {
                val = (i <= ln[r, c]) ? cell[r, c, i] : ""
                if (r == 1) line = line " " ctr(val, w[c]) " |"
                else        line = line " " val rep(" ", w[c] - length(val)) " |"
            }
            print line
        }
    }
    BEGIN { FS = FSU }
    {
        nr++
        if (NF > ncol) ncol = NF
        for (c = 1; c <= NF; c++) {
            m = split($c, L, SUB)
            if (m > ht[nr]) ht[nr] = m
            ln[nr, c] = m
            for (i = 1; i <= m; i++) {
                cell[nr, c, i] = L[i]
                if (length(L[i]) > w[c]) w[c] = length(L[i])
            }
        }
        if (ht[nr] < 1) ht[nr] = 1
        rows = nr
    }
    END {
        print bord(); prow(1); print bord()
        for (r = 2; r <= rows; r++) { prow(r); print bord() }
    }
    '
}

# One cmd_status row: NAME, STATE, client-facing ENDPOINT(s), and the
# container's own internal IPs. Ports are the *role* mapping (constant across
# promote), so they show even when the backend is stopped.
_status_row() {
    local c="$1" role="$2" bip="$3"
    local RS=$'\036' US=$'\037'
    local state endpoint ips
    state=$(_state "$c"); [[ -z "$state" ]] && state="-"
    if [[ -z "$bip" ]]; then
        endpoint="-"
    else
        case "$role" in
            active)  endpoint="${bip}:${ACTIVE_PORT} (direct)${RS}${bip}:${BOUNCER_ACTIVE_PORT} (pooled)" ;;
            staging) endpoint="${bip}:${STAGING_PORT} (direct)${RS}${bip}:${BOUNCER_STAGING_PORT} (pooled)" ;;
            *)       endpoint="${bip}" ;;
        esac
    fi
    ips=$(incus list "$c" --format json 2>/dev/null \
        | jq -r '.[0].state.network // {} | to_entries[] | select(.key != "lo") | .value.addresses[]? | select(.scope == "global") | .address' 2>/dev/null \
        | paste -sd "$RS" -)
    [[ -z "$ips" ]] && ips="-"
    printf '%s%s%s%s%s%s%s\n' "$c" "$US" "$state" "$US" "$endpoint" "$US" "$ips"
}

cmd_status() {
    local a s ca cs bip bstate
    a=$(_active); s=$(_staging)
    ca="${BACKEND_PREFIX}-${a}"; cs="${BACKEND_PREFIX}-${s}"
    bip=$(_bouncer_ip)
    bstate=$(_state "$BOUNCER"); [[ -z "$bstate" ]] && bstate="ABSENT"
    echo "active slot: $a   (active = $ca, staging = $cs)"
    # The bouncer hosts every endpoint below (its IP is the connection host),
    # so it needs no table row of its own — just its liveness.
    echo "pg-bouncer:  $bstate${bip:+ ($bip)}"
    echo
    {
        printf 'NAME\037STATE\037ENDPOINT\037IPs\n'
        _status_row "$ca" active  "$bip"
        _status_row "$cs" staging "$bip"
    } | _render_table
}

cmd_endpoint() {
    local ip
    ip=$(_bouncer_ip)
    if [[ -z "$ip" ]]; then
        echo "ERROR: pg-bouncer has no IP — is it running?" >&2
        exit 1
    fi
    cat <<EOF
Direct (pooler-free, promote-aware — use for apps, tests, and imports):
  active   host=$ip port=$ACTIVE_PORT  dbname=$PG_DB   (current data)
  staging  host=$ip port=$STAGING_PORT dbname=$PG_DB   (import target / opposite of active)

Pooled (pgbouncer, session mode — use when you need session pooling):
  active   host=$ip port=$BOUNCER_ACTIVE_PORT  dbname=$PG_DB
  staging  host=$ip port=$BOUNCER_STAGING_PORT dbname=$PG_DB

.pgpass line (one line, covers every port):
    $ip:*:*:$PG_USER:$PG_PASSWORD
EOF
}

cmd_backend_endpoint() {
    local ip
    ip=$(_bouncer_ip)
    if [[ -z "$ip" ]]; then
        echo "ERROR: pg-bouncer has no IP — is it running?" >&2
        exit 1
    fi
    cat <<EOF
direct   host=$ip port=$ACTIVE_PORT  dbname=$PG_DB   (active backend, NO pooling)
direct   host=$ip port=$STAGING_PORT dbname=$PG_DB   (staging backend, NO pooling)

The primary ports are stable, promote-aware TCP forwards (incus proxy devices
on the bouncer): the host/port never change and always route to whichever
backend fills that role, but — unlike the pooled :$BOUNCER_ACTIVE_PORT /
:$BOUNCER_STAGING_PORT — they carry no session stickiness. A client disconnect
tears down the backend connection, so test teardown's "DROP DATABASE" succeeds
instead of failing with ObjectInUse, and a bulk pg_restore isn't relayed
through the single-threaded pooler.

Use :$ACTIVE_PORT for test suites that CREATE/DROP databases, and :$STAGING_PORT
as your fast pg_restore target.

DSNs:
    postgresql://$PG_USER@$ip:$ACTIVE_PORT/$PG_DB
    postgresql://$PG_USER@$ip:$STAGING_PORT/$PG_DB
EOF
}

# PAUSE that cannot hang. PAUSE takes effect immediately but only *returns*
# once every server is released; in session pooling an idle-but-connected
# client never releases, so a bare PAUSE waits forever. We give it
# PROMOTE_PAUSE_TIMEOUT seconds to drain cleanly — in that path clients keep
# their TCP connection and get re-routed on their next query — then force the
# swap with KILL, which drops the lingering idle clients (they reconnect to the
# new backend on their next query). Either way the db ends up paused, which the
# RESUME later in cmd_promote clears.
_promote_drain() {
    local role="$1" port="$2"
    incus exec "$BOUNCER" -- env PGPASSWORD="$PG_BOUNCER_ADMIN_PASSWORD" \
        psql -h 127.0.0.1 -p "$port" -U pgb_admin -d pgbouncer \
        -c "PAUSE $PG_DB;" >/dev/null 2>&1 &
    local pid=$! waited=0
    while kill -0 "$pid" 2>/dev/null; do
        if (( waited >= PROMOTE_PAUSE_TIMEOUT )); then
            kill "$pid" 2>/dev/null || true
            echo "==> $role: PAUSE didn't drain in ${PROMOTE_PAUSE_TIMEOUT}s" \
                 "(idle session clients) — forcing them off with KILL..."
            _bouncer_admin "$role" "KILL $PG_DB;" >/dev/null
            break
        fi
        sleep 1; waited=$((waited + 1))
    done
    wait "$pid" 2>/dev/null || true
}

cmd_promote() {
    local from to
    from=$(_active)
    to=$(_staging)

    echo "==> Promoting: active $from → $to"

    # Drain (or force) both listeners. Admin commands work while paused, so we
    # can still RELOAD / RESUME below.
    _promote_drain active  "$BOUNCER_ACTIVE_PORT"
    _promote_drain staging "$BOUNCER_STAGING_PORT"

    _render_ini active  "$BOUNCER_ACTIVE_PORT"  "${BACKEND_PREFIX}-${to}"
    _render_ini staging "$BOUNCER_STAGING_PORT" "${BACKEND_PREFIX}-${from}"

    _bouncer_admin active  "RELOAD;"        >/dev/null
    _bouncer_admin staging "RELOAD;"        >/dev/null
    _bouncer_admin active  "RESUME $PG_DB;" >/dev/null
    _bouncer_admin staging "RESUME $PG_DB;" >/dev/null

    _set_active "$to"
    _set_direct_forward   # re-point the pooler-free :5432/:5433 proxies at the new roles

    echo "==> Promoted. Active: ${BACKEND_PREFIX}-${to}   Staging: ${BACKEND_PREFIX}-${from}"
    echo
    cmd_status
}

# ---------------------------------------------------------------------------
# Per-slot ops
# ---------------------------------------------------------------------------

# Block until Postgres in <container> is accepting connections.
_pg_wait_ready() {
    local container="$1" tries=0
    until incus exec "$container" -- pg_isready -q; do
        tries=$((tries + 1))
        if (( tries > 30 )); then
            echo "ERROR: Postgres on $container not ready after ${tries}s" >&2
            incus exec "$container" -- journalctl -u postgresql@17-main --no-pager | tail -n 40 >&2
            exit 1
        fi
        sleep 1
    done
}

_snapshot() {
    local container="$1" name="$2" force="${3:-}"
    if [[ "$force" == "--force" ]]; then
        incus snapshot delete "$container" "$name" 2>/dev/null || true
    fi
    # Cleanly stop Postgres so the snapshot captures a properly shut-down
    # cluster (pg_control marked clean). Otherwise `incus pause` freezes it
    # mid-flight and every restore pays for WAL replay / crash recovery.
    incus exec "$container" -- systemctl stop postgresql@17-main
    incus snapshot create "$container" "$name"
    incus exec "$container" -- systemctl start postgresql@17-main
    _pg_wait_ready "$container"
    echo "Snapshot '$name' created on $container."
}

_restore() {
    local container="$1" name="$2"
    incus stop "$container" --force 2>/dev/null || true

    # ZFS requires removing snapshots taken after the target before restoring.
    local after
    after=$(incus snapshot list "$container" -f json \
        | jq -r --arg name "$name" '
            . as $all
            | ($all | map(.name) | index($name)) as $idx
            | if $idx == null then [] else $all[$idx+1:] end
            | .[].name
        ')
    if [[ -n "$after" ]]; then
        echo "==> Snapshots on $container that will be deleted:"
        echo "$after" | sed 's/^/     /'
        local reply
        read -r -p "Continue? [Y/n] " reply
        [[ "${reply:-Y}" =~ ^[Yy]$ ]] || { echo "Aborted."; exit 1; }
        while IFS= read -r snap; do
            incus snapshot delete "$container" "$snap"
        done <<< "$after"
    fi

    incus snapshot restore "$container" "$name"
    incus start "$container"
    echo "Restored $container to snapshot '$name'."
}

_restore_last() {
    local container="$1"
    local name
    name=$(incus snapshot list "$container" -f json \
        | jq -r 'if length == 0 then empty else sort_by(.created_at) | last | .name end')
    if [[ -z "$name" ]]; then
        echo "No snapshots on $container."
        exit 1
    fi
    echo "==> Restoring $container to most recent snapshot: $name"
    _restore "$container" "$name"
}

# active slot
cmd_snapshot() {
    local name="${1:?Usage: snapshot <name> [--force]}"; shift || true
    _snapshot "$(_c_active)" "$name" "${1:-}"
}
cmd_restore() {
    local name="${1:?Usage: restore <name>}"
    _restore "$(_c_active)" "$name"
}
cmd_restore_last() { _restore_last "$(_c_active)"; }

# Unified listing for both slots.
cmd_snapshots() {
    local a s
    a=$(_active); s=$(_staging)
    echo "─── active  (${BACKEND_PREFIX}-${a}) ───"
    incus snapshot list "${BACKEND_PREFIX}-${a}"
    echo
    echo "─── staging (${BACKEND_PREFIX}-${s}) ───"
    incus snapshot list "${BACKEND_PREFIX}-${s}"
}

# staging slot
cmd_staging_snapshot() {
    local name="${1:?Usage: staging.snapshot <name> [--force]}"; shift || true
    _snapshot "$(_c_staging)" "$name" "${1:-}"
}
cmd_staging_restore() {
    local name="${1:?Usage: staging.restore <name>}"
    _restore "$(_c_staging)" "$name"
}
cmd_staging_restore_last() { _restore_last "$(_c_staging)"; }
cmd_staging_reset()        { _restore "$(_c_staging)" initial; }
cmd_staging_stop()         { incus stop "$(_c_staging)"; }
cmd_staging_start()        { incus start "$(_c_staging)"; }

# Shell / psql / ip / logs, per slot.
_psql() {
    local container="$1"; shift
    incus exec "$container" -- env PGPASSWORD="$PG_PASSWORD" \
        psql -U "$PG_USER" "$PG_DB" "$@"
}
cmd_psql()         { _psql "$(_c_active)"  "$@"; }
cmd_staging_psql() { _psql "$(_c_staging)" "$@"; }

cmd_shell()         { incus exec "$(_c_active)"  -- bash; }
cmd_staging_shell() { incus exec "$(_c_staging)" -- bash; }

_ip() {
    # Empty if container has no IPv4 (stopped, frozen, just-launched).
    incus list "$1" --format csv -c 4 2>/dev/null \
        | grep -oE '[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+' \
        | head -1 || true
}

# IPv4 when running; otherwise the lifecycle state (STOPPED, FROZEN, …).
_ip_or_state() {
    local container="$1" ip
    ip=$(_ip "$container")
    if [[ -n "$ip" ]]; then
        echo "$ip"
    else
        echo "$(_state "$container")"
    fi
}

# Unified port + backend view for both slots. The bouncer endpoint
# (host:port) is the client-facing fact; the backend column shows its
# container IP when running, or its state (STOPPED, …) when not.
cmd_ip() {
    local a s info_a info_s bouncer_ip endpoint_a endpoint_s
    a=$(_active); s=$(_staging)
    info_a=$(_ip_or_state "${BACKEND_PREFIX}-${a}")
    info_s=$(_ip_or_state "${BACKEND_PREFIX}-${s}")
    bouncer_ip=$(_bouncer_ip)
    if [[ -n "$bouncer_ip" ]]; then
        endpoint_a="${bouncer_ip}:${ACTIVE_PORT}"
        endpoint_s="${bouncer_ip}:${STAGING_PORT}"
    else
        endpoint_a="pg-bouncer $(_state "$BOUNCER")"
        endpoint_s="pg-bouncer $(_state "$BOUNCER")"
    fi
    printf '%-8s  %-22s  →  %-10s (%s)\n' \
        active  "$endpoint_a" "${BACKEND_PREFIX}-${a}" "$info_a"
    printf '%-8s  %-22s  →  %-10s (%s)\n' \
        staging "$endpoint_s" "${BACKEND_PREFIX}-${s}" "$info_s"
}

cmd_logs()         { incus exec "$(_c_active)"  -- tail -f /var/log/postgresql/postgresql-17-main.log; }
cmd_staging_logs() { incus exec "$(_c_staging)" -- tail -f /var/log/postgresql/postgresql-17-main.log; }

cmd_bouncer_logs() {
    incus exec "$BOUNCER" -- \
        tail -f /var/log/pgbouncer/active.log /var/log/pgbouncer/staging.log
}

# RELOAD pgbouncer@<role> if it already answers on its target admin port;
# otherwise restart it and wait for it to come up. RELOAD re-reads
# databases/auth but NOT listen_port, so moving the pooler onto a new port
# (the 5432→5442 / 5433→5443 migration) requires a restart. In steady state
# this is a plain zero-downtime RELOAD.
_ensure_bouncer_listening() {
    local role="$1" port="$2"
    if _bouncer_admin "$role" "SHOW VERSION;" >/dev/null 2>&1; then
        _bouncer_admin "$role" "RELOAD;" >/dev/null
        return 0
    fi
    echo "==> pgbouncer@$role not on :$port yet — restarting to apply listen_port..."
    incus exec "$BOUNCER" -- systemctl restart "pgbouncer@${role}"
    local tries=0
    until _bouncer_admin "$role" "SHOW VERSION;" >/dev/null 2>&1; do
        tries=$((tries + 1))
        if (( tries > 20 )); then
            echo "ERROR: pgbouncer@$role not responding on :$port after restart" >&2
            incus exec "$BOUNCER" -- journalctl -u "pgbouncer@${role}" --no-pager | tail -n 40 >&2
            exit 1
        fi
        sleep 1
    done
}

cmd_bouncer_reload() {
    # Self-heal the backends' static IP pinning before reloading. Backends
    # provisioned before pinning (or with a drifted lease) would otherwise
    # leave pgbouncer unable to resolve them by name. Idempotent — a no-op
    # when both backends already sit on their pinned addresses.
    _repair_backend_ip "$BACKEND_A" "$(_pick_backend_a_ip)"
    _repair_backend_ip "$BACKEND_B" "$(_pick_backend_b_ip)"

    # Re-render both inis from the current pointer state on the pgbouncer ports
    # (:5442 active, :5443 staging), then RELOAD — or restart, when migrating
    # the pooler off the old primary ports. Freeing :5432/:5433 here is also
    # what lets the direct proxies below bind them inside the bouncer's netns.
    local a s
    a=$(_active); s=$(_staging)
    _render_ini active  "$BOUNCER_ACTIVE_PORT"  "${BACKEND_PREFIX}-${a}"
    _render_ini staging "$BOUNCER_STAGING_PORT" "${BACKEND_PREFIX}-${s}"
    _ensure_bouncer_listening active  "$BOUNCER_ACTIVE_PORT"
    _ensure_bouncer_listening staging "$BOUNCER_STAGING_PORT"

    # Retire the pre-migration single direct device (old :5434) if present,
    # then create-or-re-point the two direct-forward proxies (:5432 → active,
    # :5433 → staging) in lockstep. This is also how existing deployments
    # acquire the devices — and `make start` runs bouncer.reload, so they're
    # re-asserted on every VM boot.
    incus config device remove "$BOUNCER" "$LEGACY_DIRECT_DEVICE" >/dev/null 2>&1 || true
    _set_direct_forward

    echo "Reloaded pgbouncer@active (:$BOUNCER_ACTIVE_PORT) and pgbouncer@staging (:$BOUNCER_STAGING_PORT)."
    echo "Direct proxies: :$ACTIVE_PORT → active, :$STAGING_PORT → staging."
}

# ---------------------------------------------------------------------------
# Export / import (operate on the active backend)
# ---------------------------------------------------------------------------

cmd_export() {
    mkdir -p "$REPO_ROOT/var"
    local container
    container=$(_c_active)
    local file
    file="$REPO_ROOT/var/${container}-$(date +%Y-%m-%dT%H-%M-%S).tar.gz"
    echo "==> Pausing $container for consistent export..."
    incus pause "$container"
    incus export "$container" "$file"
    incus resume "$container"
    echo "Exported to $file"
}

cmd_import_last() {
    local container
    container=$(_c_active)
    local file
    file=$(ls -t "$REPO_ROOT/var/${container}-"*.tar.gz 2>/dev/null | head -1)
    if [[ -z "$file" ]]; then
        echo "No export found for $container in var/."
        exit 1
    fi
    echo "==> Importing from $file..."
    incus delete "$container" --force 2>/dev/null || true
    incus import "$file"
    incus start "$container"
    echo "Imported and started $container"
}

# ---------------------------------------------------------------------------
# Dispatcher
# ---------------------------------------------------------------------------

usage() {
    cat <<EOF
Usage: $(basename "$0") <command> [args]

Lifecycle:
  up                              provision pg-dev-a, pg-dev-b, pg-bouncer
  down                            delete all three containers
  status                          show pointer + container states
  endpoint                        print bouncer host/port roles + .pgpass line
  backend-endpoint                print the stable, promote-aware, pooler-free
                                  direct dsns (:$ACTIVE_PORT active,
                                  :$STAGING_PORT staging) — active for tests
                                  that CREATE/DROP databases, staging for fast
                                  pg_restore imports
  promote                         flip active↔staging on both bouncer instances

Both slots (rendered side by side):
  ip                              bouncer endpoint → backend, for both slots
  snapshots                       snapshot lists for active and staging

Active slot (whatever is currently active):
  psql [args]                     psql via incus exec into active backend
  shell                           bash into active backend
  logs                            tail postgres logs on active backend
  snapshot <name> [--force]       create a snapshot on active backend
  restore <name>                  restore active backend to a snapshot
  restore-last                    restore active backend to its most recent snapshot

Staging slot (the other one):
  staging.psql [args]
  staging.shell
  staging.logs
  staging.snapshot <name> [--force]
  staging.restore <name>
  staging.restore-last
  staging.reset                   shortcut: restore staging to 'initial'
  staging.stop                    stop staging backend
  staging.start                   start staging backend

Bouncer:
  bouncer.logs                    tail both pgbouncer logs
  bouncer.reload                  re-render both inis from state and RELOAD

Export / import (act on the active backend):
  export                          export active backend to var/<name>-<ts>.tar.gz
  import-last                     re-import most recent export of active backend
EOF
}

case "${1:-}" in
    up)             shift; cmd_up "$@" ;;
    down)           shift; cmd_down "$@" ;;
    status)         shift; cmd_status "$@" ;;
    endpoint)         shift; cmd_endpoint "$@" ;;
    backend-endpoint) shift; cmd_backend_endpoint "$@" ;;
    promote)          shift; cmd_promote "$@" ;;

    psql)           shift; cmd_psql "$@" ;;
    shell)          shift; cmd_shell "$@" ;;
    ip)             shift; cmd_ip "$@" ;;
    logs)           shift; cmd_logs "$@" ;;
    snapshot)       shift; cmd_snapshot "$@" ;;
    restore)        shift; cmd_restore "$@" ;;
    restore-last)   shift; cmd_restore_last "$@" ;;
    snapshots)      shift; cmd_snapshots "$@" ;;

    staging.psql)         shift; cmd_staging_psql "$@" ;;
    staging.shell)        shift; cmd_staging_shell "$@" ;;
    staging.logs)         shift; cmd_staging_logs "$@" ;;
    staging.snapshot)     shift; cmd_staging_snapshot "$@" ;;
    staging.restore)      shift; cmd_staging_restore "$@" ;;
    staging.restore-last) shift; cmd_staging_restore_last "$@" ;;
    staging.reset)        shift; cmd_staging_reset "$@" ;;
    staging.stop)         shift; cmd_staging_stop "$@" ;;
    staging.start)        shift; cmd_staging_start "$@" ;;

    bouncer.logs)   shift; cmd_bouncer_logs "$@" ;;
    bouncer.reload) shift; cmd_bouncer_reload "$@" ;;

    export)         shift; cmd_export "$@" ;;
    import-last)    shift; cmd_import_last "$@" ;;

    ""|-h|--help)   usage ;;
    *)              usage; exit 1 ;;
esac
