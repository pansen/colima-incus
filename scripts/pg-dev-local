#!/usr/bin/env bash
set -Eeuo pipefail
# set -x

# pg-dev-local — two PostgreSQL backends, two client-facing ports, one tiny
# proxy. See README.md's Design section for the rationale.
#
#   pg-dev-a, pg-dev-b   long-lived backends with their own snapshot timelines
#   pg-proxy             a bare container that hosts two incus `proxy`
#                        devices — no software installed:
#                          :5432  → the *active*  backend's Postgres
#                          :5433  → the *staging* backend's Postgres
#                        The devices bind on the Apple machine host, because
#                        macOS cannot route to the nested incusbr0 subnet.
#                        Clients connect to the machine IP; `promote` flips
#                        var/active-slot and re-points the two targets.
#
# There is no pgbouncer: each port is a plain per-connection TCP passthrough,
# indistinguishable from a direct connection (prepared statements, SET, LISTEN,
# CREATE/DROP DATABASE all work), so no pooling, no userlist/SCRAM to maintain,
# no PAUSE/RESUME drain on promote, and no separate "direct" port.

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=../.env
[[ -f "$REPO_ROOT/.env" ]] && source "$REPO_ROOT/.env"

PG_USER="${PG_USER:?PG_USER must be set in .env}"
PG_DB="${PG_DB:?PG_DB must be set in .env}"
PG_PASSWORD="${PG_PASSWORD:?PG_PASSWORD must be set in .env}"

IMAGE=images:ubuntu/24.04/cloud
BACKEND_PREFIX=pg-dev
BACKEND_A="${BACKEND_PREFIX}-a"
BACKEND_B="${BACKEND_PREFIX}-b"
PROXY=pg-proxy
STATE_DIR="$REPO_ROOT/var"
STATE_FILE="$STATE_DIR/active-slot"
DATA_ROOT=/var/lib/pg-dev-local
DATA_IMAGE=/var/lib/pg-dev-local.xfs
MUTATION_LOCK=/run/lock/pg-dev-local.lock
SIGNAL_CLEANUP=

# State-changing commands install a short-lived cleanup callback while they
# own stopped containers, temporary data trees, or an unmounted filesystem.
# Bash resolves locals dynamically, so the callback can safely use the state
# tracked by the command that installed it.
_handle_exit() {
    local status="$1"
    trap - ERR HUP INT TERM
    set +eu
    if [[ -n "$SIGNAL_CLEANUP" ]] && declare -F "$SIGNAL_CLEANUP" >/dev/null; then
        "$SIGNAL_CLEANUP"
    fi
    exit "$status"
}

trap '_handle_exit $?' ERR
trap '_handle_exit 129' HUP
trap '_handle_exit 130' INT
trap '_handle_exit 143' TERM

# Client-facing ports. Both are pooler-free *direct* lines — incus `proxy`
# devices on pg-proxy that relay a raw TCP connection straight to the
# backend's Postgres, no pgbouncer in the path. They follow promote (we
# re-point each device's `connect` when active flips) and carry no session
# stickiness: a client disconnect tears down the backend connection, so
# "DROP DATABASE" in test teardown succeeds instead of failing with
# ObjectInUse, and a bulk `pg_restore` isn't funneled through a pooler.
ACTIVE_PORT="${PG_ACTIVE_PORT:-5432}"            # direct proxy → active backend
STAGING_PORT="${PG_STAGING_PORT:-5433}"          # direct proxy → staging backend

# The two proxy devices on pg-proxy (active + staging).
MAIN_DEVICE=main
STAGING_DEVICE=staging

# ---------------------------------------------------------------------------
# State helpers
# ---------------------------------------------------------------------------

_active()    { cat "$STATE_FILE" 2>/dev/null || echo a; }
_staging()   { [[ "$(_active)" == a ]] && echo b || echo a; }
_c_active()  { echo "${BACKEND_PREFIX}-$(_active)"; }
_c_staging() { echo "${BACKEND_PREFIX}-$(_staging)"; }

_set_active() {
    local new="$1"
    mkdir -p "$STATE_DIR"
    local tmp
    tmp="$(mktemp "$STATE_FILE.XXXXXX")"
    printf '%s\n' "$new" > "$tmp"
    mv "$tmp" "$STATE_FILE"
    if [[ -n "${HOST_UID:-}" && -n "${HOST_GID:-}" ]]; then
        chown "$HOST_UID:$HOST_GID" "$STATE_DIR" "$STATE_FILE" 2>/dev/null || true
    fi
}

_slot_for_container() {
    case "$1" in
        "$BACKEND_A") echo a ;;
        "$BACKEND_B") echo b ;;
        *) echo "ERROR: unknown backend container '$1'" >&2; exit 1 ;;
    esac
}

_data_current()   { echo "$DATA_ROOT/$(_slot_for_container "$1")/current"; }
_data_snapshots() { echo "$DATA_ROOT/$(_slot_for_container "$1")/snapshots"; }

_acquire_mutation_lock() {
    mkdir -p "$(dirname "$MUTATION_LOCK")"
    exec 9>"$MUTATION_LOCK"
    flock 9
}

_data_store_mounted() {
    [[ -f "$DATA_IMAGE" \
        && "$(findmnt -T "$DATA_ROOT" -n -o FSTYPE 2>/dev/null || true)" == xfs ]]
}

_require_data_store() {
    if ! _data_store_mounted; then
        echo "ERROR: $DATA_ROOT is not mounted from the XFS data store; run 'make machine' first." >&2
        return 1
    fi
}

# ---------------------------------------------------------------------------
# Proxy helpers
# ---------------------------------------------------------------------------

_proxy_ip() {
    # The nested incusbr0 addresses are not routed to macOS. Proxy devices
    # therefore bind on the Incus host, which is this Apple machine's eth0.
    if [[ -n "${PG_MACHINE_IP:-}" ]]; then
        echo "$PG_MACHINE_IP"
        return
    fi
    # `|| true`: don't let a missing eth0 (e.g. no interface yet) trip the ERR
    # trap — callers already fall back to "?" / state text on empty output.
    ip -4 -o addr show dev eth0 2>/dev/null \
        | awk '{ split($4, a, "/"); print a[1]; exit }' || true
}

# RUNNING / STOPPED / FROZEN / … — empty if the container doesn't exist.
_state() {
    incus list "$1" --format csv -c s 2>/dev/null | head -n1 || true
}

# The /24 prefix of incusbr0, e.g. "10.224.165" from "10.224.165.1/24".
_incusbr0_prefix() {
    local addr
    addr=$(incus network get incusbr0 ipv4.address 2>/dev/null || true)
    if [[ -z "$addr" || "$addr" == "none" ]]; then
        echo "ERROR: cannot read incusbr0 ipv4.address; set the IPs explicitly in .env" >&2
        exit 1
    fi
    local prefix=${addr%.*}
    echo "${prefix%%/*}"
}

# Static IPs for the backends. They MUST keep a stable address: the proxy
# devices dial them by IP, and a pinned ipv4.address yields a STATIC lease
# that Incus regenerates on daemon start (so the target survives a machine
# reboot). A dynamic lease could drift to a different address and break the
# forward. Override in .env if .11/.12 clash.
_pick_backend_a_ip() { echo "${PG_BACKEND_A_IP:-$(_incusbr0_prefix).11}"; }
_pick_backend_b_ip() { echo "${PG_BACKEND_B_IP:-$(_incusbr0_prefix).12}"; }

# The current IPv4 of a container, or empty if it has none / doesn't exist.
_container_ip() {
    incus list "$1" --format csv -c 4 2>/dev/null \
        | grep -oE '[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+' \
        | head -1 || true
}

# _repair_backend_ip <container> <wanted-ip>
# Make sure <container> owns the pinned static IP <wanted-ip>. Self-heal for a
# backend whose eth0 was never pinned (pre-dates IP pinning) or whose lease
# has otherwise drifted. Fully idempotent: when everything is already correct
# it touches nothing, so it's safe on every `refresh` / `make start`.
_repair_backend_ip() {
    local container="$1" want="$2"
    [[ -z "$want" ]] && return 0
    incus info "$container" >/dev/null 2>&1 || return 0   # not provisioned yet

    # 1) Pin the device address if it's missing or wrong. `override` creates
    #    the local device over the profile-inherited NIC; once it's already
    #    local, `override` fails and `set` is the right verb.
    local have
    have=$(incus config device get "$container" eth0 ipv4.address 2>/dev/null || true)
    if [[ "$have" != "$want" ]]; then
        echo "==> Pinning $container eth0 → $want (was ${have:-unset})..."
        incus config device override "$container" eth0 ipv4.address="$want" 2>/dev/null \
            || incus config device set "$container" eth0 ipv4.address="$want"
    fi

    # 2) A running backend on the wrong address needs a restart for the new
    #    static lease to take hold; a stopped one picks it up on next start.
    if [[ "$(_state "$container")" == "RUNNING" && "$(_container_ip "$container")" != "$want" ]]; then
        echo "==> Restarting $container to apply $want..."
        incus restart "$container"
        until [[ "$(_container_ip "$container")" == "$want" ]]; do sleep 1; done
    fi
}

# The pinned IP of whichever backend is currently active / staging.
_active_backend_ip() {
    if [[ "$(_active)" == a ]]; then _pick_backend_a_ip; else _pick_backend_b_ip; fi
}
_staging_backend_ip() {
    if [[ "$(_staging)" == a ]]; then _pick_backend_a_ip; else _pick_backend_b_ip; fi
}

# Add-or-re-point one proxy device. `bind=host` puts its listener on the Apple
# machine's eth0 (reachable from macOS); the Incus host namespace can also
# dial the backend's pinned incusbr0 address. Existing bind=instance devices
# from the Colima layout are replaced in place.
_ensure_proxy_device() {
    local device="$1" listen_port="$2" ip="$3"
    local bind
    bind=$(incus config device get "$PROXY" "$device" bind 2>/dev/null || true)
    if [[ "$bind" == host ]]; then
        incus config device set "$PROXY" "$device" \
            listen="tcp:0.0.0.0:${listen_port}" connect="tcp:${ip}:5432" || return
    else
        incus config device remove "$PROXY" "$device" >/dev/null 2>&1 || true
        echo "==> Adding proxy $PROXY:$listen_port → ${ip}:5432..."
        incus config device add "$PROXY" "$device" proxy \
            listen="tcp:0.0.0.0:${listen_port}" connect="tcp:${ip}:5432" bind=host >/dev/null || return
    fi
}

# Ensure both proxy devices exist and point at the right backends: :5432 →
# active, :5433 → staging. Re-pointed on promote / refresh / VM boot. A no-op
# when pg-proxy isn't running.
_set_forwards() {
    [[ "$(_state "$PROXY")" == "RUNNING" ]] || return 0
    _ensure_proxy_device "$MAIN_DEVICE"    "$ACTIVE_PORT"  "$(_active_backend_ip)" || return
    _ensure_proxy_device "$STAGING_DEVICE" "$STAGING_PORT" "$(_staging_backend_ip)" || return
}

# ---------------------------------------------------------------------------
# Provisioning
# ---------------------------------------------------------------------------

# Block until <container> reports an IPv4 on eth0 — any address, or the
# specific <expected-ip> when given (e.g. right after pinning a static lease,
# where only that exact address means the new lease actually took hold).
_wait_for_ipv4() {
    local container="$1" expected="${2:-}"
    if [[ -n "$expected" ]]; then
        until incus list "$container" --format csv -c 4 | grep -q "$expected"; do
            sleep 1
        done
    else
        until incus list "$container" --format csv -c 4 | grep -qE '[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+'; do
            sleep 2
        done
    fi
}

_provision_backend() {
    local container="$1" ip="$2"
    local data_dir
    data_dir=$(_data_current "$container")

    echo "==> Launching $container from $IMAGE..."
    echo "    The first backend downloads and unpacks the Ubuntu image; later launches reuse it."
    # `incus launch` accepts optional YAML configuration on stdin. The outer
    # Apple `container machine run --interactive` keeps stdin open, so without
    # this redirect Incus waits forever before it creates an operation.
    incus launch --verbose "$IMAGE" "$container" </dev/null

    echo "==> Attaching XFS-reflinked PostgreSQL data at $data_dir..."
    mkdir -p "$data_dir"
    incus exec "$container" -- mkdir -p /var/lib/postgresql
    incus config device add "$container" pgdata disk \
        source="$data_dir" path=/var/lib/postgresql shift=true

    echo "==> Waiting for IPv4 on $container..."
    _wait_for_ipv4 "$container"

    echo "==> Pinning $container eth0 → $ip (static lease → stable proxy target)..."
    incus config device override "$container" eth0 ipv4.address="$ip"
    incus restart "$container"
    _wait_for_ipv4 "$container" "$ip"

    echo "==> Installing PostgreSQL 17 on $container..."
    incus exec --verbose "$container" -- bash <<'SETUP'
set -euo pipefail
export DEBIAN_FRONTEND=noninteractive

apt-get update -q
apt-get install -y curl gnupg lsb-release

curl -fsSL https://www.postgresql.org/media/keys/ACCC4CF8.asc \
    | gpg --dearmor -o /etc/apt/trusted.gpg.d/pgdg.gpg
echo "deb https://apt.postgresql.org/pub/repos/apt $(lsb_release -cs)-pgdg main" \
    > /etc/apt/sources.list.d/pgdg.list
apt-get update -q
apt-get install -y --no-install-recommends postgresql-17

mkdir -p /etc/postgresql/17/main/conf.d
cat > /etc/postgresql/17/main/conf.d/99-dev.conf <<'PGCONF'
listen_addresses = '*'
dynamic_shared_memory_type = posix

shared_buffers = 2GB
effective_cache_size = 6GB
work_mem = 32MB
maintenance_work_mem = 1GB
max_parallel_maintenance_workers = 4

max_wal_size = 16GB
checkpoint_timeout = 30min
checkpoint_completion_target = 0.8
wal_level = minimal
max_wal_senders = 0

fsync = off
full_page_writes = off
synchronous_commit = off
autovacuum = off

log_destination = stderr
logging_collector = off
log_min_duration_statement = 0
log_checkpoints = on
log_lock_waits = on
deadlock_timeout = 100
debug_pretty_print = on
PGCONF

cat > /etc/postgresql/17/main/pg_hba.conf <<'PGHBA'
local   all   postgres                peer
local   all   all                     md5
host    all   all   0.0.0.0/0         scram-sha-256
host    all   all   ::/0              scram-sha-256
PGHBA

systemctl restart postgresql@17-main
SETUP

    echo "==> Creating role '$PG_USER' and database '$PG_DB' on $container..."
    incus exec --verbose "$container" -- su -c psql postgres <<SQL
CREATE ROLE "$PG_USER" WITH LOGIN PASSWORD '$PG_PASSWORD' SUPERUSER;
CREATE DATABASE "$PG_DB" OWNER "$PG_USER";
SQL

    echo "==> Snapshotting $container @ initial..."
    _snapshot "$container" initial
}

# pg-proxy is a bare container: no packages, no config. It exists only to own
# the two proxy devices (added by _set_forwards). With bind=host, both their
# listeners and backend connections live in the Apple machine host namespace.
_provision_proxy() {
    echo "==> Launching $PROXY from the cached Ubuntu image (bare proxy container)..."
    incus launch --verbose "$IMAGE" "$PROXY" </dev/null

    echo "==> Waiting for IPv4 on $PROXY..."
    _wait_for_ipv4 "$PROXY"
}

# ---------------------------------------------------------------------------
# Lifecycle commands
# ---------------------------------------------------------------------------

cmd_up() {
    _require_data_store

    for c in "$BACKEND_A" "$BACKEND_B" "$PROXY"; do
        if incus info "$c" > /dev/null 2>&1; then
            echo "Container '$c' already exists — run '$0 down' first."
            exit 1
        fi
    done

    local backend_a_ip backend_b_ip
    backend_a_ip=$(_pick_backend_a_ip)
    backend_b_ip=$(_pick_backend_b_ip)
    echo "==> Static backend IPs: $BACKEND_A=$backend_a_ip  $BACKEND_B=$backend_b_ip"

    _provision_backend "$BACKEND_A" "$backend_a_ip"
    _provision_backend "$BACKEND_B" "$backend_b_ip"
    _provision_proxy

    _set_active a
    _set_forwards

    echo
    echo "==> pg-dev ready."
    echo
    cmd_endpoint
}

# Best-effort teardown: an unmounted data store or a container that refuses
# to delete must not stop the rest of the cleanup from proceeding. Deleting
# containers is tried for all three regardless of individual failures; the
# XFS data trees are only removed once every container is confirmed gone AND
# the store is actually mounted (removing them while unmounted would just
# hollow out the mountpoint directory, not the XFS-backed data).
cmd_down() {
    local c slot path failed=0
    for c in "$PROXY" "$BACKEND_A" "$BACKEND_B"; do
        if incus info "$c" >/dev/null 2>&1; then
            if ! incus delete "$c" --force; then
                echo "WARNING: failed to delete $c; continuing with the rest." >&2
                failed=1
            fi
        fi
    done

    if (( failed != 0 )); then
        echo "ERROR: one or more containers could not be deleted; refusing to remove their backing data." >&2
    elif mountpoint -q "$DATA_ROOT"; then
        for slot in a b; do
            path="$DATA_ROOT/$slot"
            [[ "$path" == "$DATA_ROOT/"[ab] ]] || {
                echo "ERROR: refusing to remove unexpected data path '$path'" >&2
                exit 1
            }
            rm -rf -- "$path"
        done
    else
        echo "WARNING: $DATA_ROOT is not mounted; the XFS data trees were left alone." >&2
    fi

    rm -f "$STATE_FILE"
    (( failed == 0 )) || return 1
}

# Box-table renderer for cmd_status. Reads rows on stdin; columns are separated
# by US (\037) and multi-line cells split on RS (\036). The first row is the
# header (centered); data cells are left-aligned. Mirrors incus's own table
# look (a border after every row) so the two outputs sit together naturally.
_render_table() {
    awk -v FSU=$'\037' -v SUB=$'\036' '
    function rep(ch, n,   s) { s = ""; while (n-- > 0) s = s ch; return s }
    function bord(   c, s) { s = "+"; for (c = 1; c <= ncol; c++) s = s rep("-", w[c] + 2) "+"; return s }
    function ctr(str, width,   t, l) { t = width - length(str); l = int(t / 2); return rep(" ", l) str rep(" ", t - l) }
    function prow(r,   i, c, val, line) {
        for (i = 1; i <= ht[r]; i++) {
            line = "|"
            for (c = 1; c <= ncol; c++) {
                val = (i <= ln[r, c]) ? cell[r, c, i] : ""
                if (r == 1) line = line " " ctr(val, w[c]) " |"
                else        line = line " " val rep(" ", w[c] - length(val)) " |"
            }
            print line
        }
    }
    BEGIN { FS = FSU }
    {
        nr++
        if (NF > ncol) ncol = NF
        for (c = 1; c <= NF; c++) {
            m = split($c, L, SUB)
            if (m > ht[nr]) ht[nr] = m
            ln[nr, c] = m
            for (i = 1; i <= m; i++) {
                cell[nr, c, i] = L[i]
                if (length(L[i]) > w[c]) w[c] = length(L[i])
            }
        }
        if (ht[nr] < 1) ht[nr] = 1
        rows = nr
    }
    END {
        print bord(); prow(1); print bord()
        for (r = 2; r <= rows; r++) { prow(r); print bord() }
    }
    '
}

# One cmd_status row: NAME, STATE, client-facing ENDPOINT, snapshot count, and
# the container's own bridge IPs. ENDPOINT is the published proxy-ip:port — the
# *role* mapping (constant across promote), so it shows even when the backend
# is stopped. The backend's own IP isn't repeated here (it's in the IPs column
# and, being on incusbr0, isn't reachable from macOS anyway).
_status_row() {
    local c="$1" role="$2" proxy_ip="$3"
    local RS=$'\036' US=$'\037'
    local state endpoint ips snaps port json
    json=$(incus list "$c" --format json 2>/dev/null)
    # Single incus call for both state and IPs (was a separate `_state` call
    # plus this same `incus list --format json`).
    state=$(printf '%s' "$json" | jq -r '.[0].status // empty | ascii_upcase' 2>/dev/null)
    [[ -z "$state" ]] && state="-"
    case "$role" in
        active)  port="$ACTIVE_PORT" ;;
        staging) port="$STAGING_PORT" ;;
    esac
    endpoint="${proxy_ip:-?}:${port}"
    ips=$(printf '%s' "$json" \
        | jq -r '.[0].state.network // {} | to_entries[] | select(.key != "lo") | .value.addresses[]? | select(.scope == "global") | .address' 2>/dev/null \
        | paste -sd "$RS" -)
    [[ -z "$ips" ]] && ips="-"
    snaps=$(_snapshot_count "$c")
    printf '%s%s%s%s%s%s%s%s%s\n' \
        "$c" "$US" "$state" "$US" "$endpoint" "$US" "$snaps" "$US" "$ips"
}

# The one status view: incus client/server versions, slot + proxy roles, a
# per-backend table, then the snapshot timelines. Called by `make status` (and
# after promote / staging start-stop), so it is the single place that answers
# "what's running, where do I connect, and what can I roll back to".
cmd_status() {
    local a s ca cs proxy_ip pstate
    a=$(_active); s=$(_staging)
    ca="${BACKEND_PREFIX}-${a}"; cs="${BACKEND_PREFIX}-${s}"
    proxy_ip=$(_proxy_ip)
    pstate=$(_state "$PROXY"); [[ -z "$pstate" ]] && pstate="ABSENT"

    incus version 2>/dev/null
    echo
    echo "active slot: $a   (active = $ca, staging = $cs)"
    # pg-proxy owns every client-facing proxy device below, but bind=host puts
    # the listeners on the Apple machine address shown here.
    if [[ "$pstate" == "RUNNING" ]]; then
        echo "pg-proxy:    $pstate  ($proxy_ip → :$ACTIVE_PORT active, :$STAGING_PORT staging)"
    else
        echo "pg-proxy:    $pstate"
    fi
    if ! _data_store_mounted; then
        echo "data store:  NOT MOUNTED — run 'make machine'"
    fi
    echo
    {
        printf 'NAME\037STATE\037ENDPOINT\037SNAPSHOTS\037IPs\n'
        _status_row "$ca" active  "$proxy_ip"
        _status_row "$cs" staging "$proxy_ip"
    } | _render_table
    echo
    cmd_snapshots --with-psql
}

_print_psql_command() {
    local label="$1" ip="$2" port="$3"
    printf '%spsql --host=%q --port=%q --username=%q --dbname=%q\n' \
        "$label" "$ip" "$port" "$PG_USER" "$PG_DB"
}

cmd_endpoint() {
    if [[ "$(_state "$PROXY")" != "RUNNING" ]]; then
        echo "ERROR: $PROXY is not running — 'make start' (then 'make pg.up' if it was never provisioned)." >&2
        exit 1
    fi
    local ip
    ip=$(_proxy_ip)
    cat <<EOF
active   host=$ip port=$ACTIVE_PORT dbname=$PG_DB   (current data)
staging  host=$ip port=$STAGING_PORT dbname=$PG_DB   (import target / opposite of active)

.pgpass line (one line, covers both ports):
    $ip:*:*:$PG_USER:$PG_PASSWORD
EOF

    echo
    echo "psql commands:"
    _print_psql_command "  active:  " "$ip" "$ACTIVE_PORT"
    _print_psql_command "  staging: " "$ip" "$STAGING_PORT"
}

cmd_promote() {
    local from to result=0 pointer_flipped=0
    from=$(_active)
    to=$(_staging)

    echo "==> Promoting: active $from → $to"

    local proxy_state from_state to_state problems=() line
    proxy_state=$(_state "$PROXY")
    from_state=$(_state "${BACKEND_PREFIX}-${from}")
    to_state=$(_state "${BACKEND_PREFIX}-${to}")
    [[ "$proxy_state" == RUNNING ]] \
        || problems+=("$PROXY is ${proxy_state:-ABSENT} — run 'make start'")
    [[ "$from_state" == RUNNING ]] \
        || problems+=("${BACKEND_PREFIX}-${from} (active) is ${from_state:-ABSENT} — run 'make start'")
    [[ "$to_state" == RUNNING ]] \
        || problems+=("${BACKEND_PREFIX}-${to} (staging) is ${to_state:-ABSENT} — run 'make pg.staging.start'")
    if (( ${#problems[@]} > 0 )); then
        echo "ERROR: promotion requires proxy and both backends RUNNING:" >&2
        for line in "${problems[@]}"; do
            echo "  - $line" >&2
        done
        exit 1
    fi

    _promote_signal_cleanup() {
        set +e
        if (( pointer_flipped == 1 )); then
            _set_active "$from"
            _set_forwards
        fi
    }
    SIGNAL_CLEANUP=_promote_signal_cleanup

    # Flip the pointer, then re-point both forwards. Re-pointing a proxy
    # device's `connect` restarts its forkproxy, so any open TCP connection is
    # dropped — clients reconnect (to the new active on :$ACTIVE_PORT, or the
    # new staging on :$STAGING_PORT). The endpoints themselves never change.
    pointer_flipped=1
    _set_active "$to"
    if _set_forwards; then
        result=0
    else
        result=$?
        echo "ERROR: proxy update failed; restoring active slot $from..." >&2
        _set_active "$from"
        pointer_flipped=0
        _set_forwards || echo "ERROR: proxy rollback also failed; run 'make pg.refresh'." >&2
        SIGNAL_CLEANUP=
        unset -f _promote_signal_cleanup
        return "$result"
    fi
    pointer_flipped=0
    SIGNAL_CLEANUP=
    unset -f _promote_signal_cleanup

    echo "==> Promoted. Active: ${BACKEND_PREFIX}-${to}   Staging: ${BACKEND_PREFIX}-${from}"
    echo
    cmd_status
}

# ---------------------------------------------------------------------------
# Per-slot ops
# ---------------------------------------------------------------------------

# Block until Postgres in <container> is accepting connections.
_pg_wait_ready() {
    local container="$1" tries=0
    until incus exec "$container" -- pg_isready -q; do
        tries=$((tries + 1))
        if (( tries > 30 )); then
            echo "ERROR: Postgres on $container not ready after ${tries}s" >&2
            incus exec "$container" -- journalctl -u postgresql@17-main --no-pager | tail -n 40 >&2
            return 1
        fi
        sleep 1
    done
}

# Stop <container> and verify it actually lands in STOPPED, refusing to
# proceed otherwise (callers are about to touch its data). Plain `incus stop`
# by default; pass --force for `incus stop --force` when an unclean stop is
# preferable to hanging.
_stop_checked() {
    local container="$1" force="${2:-}" state
    state=$(_state "$container")
    if [[ -z "$state" ]]; then
        echo "ERROR: container '$container' does not exist." >&2
        return 1
    fi
    if [[ "$state" != STOPPED ]]; then
        if [[ "$force" == --force ]]; then
            incus stop "$container" --force || return
        else
            incus stop "$container" || return
        fi
    fi
    state=$(_state "$container")
    if [[ "$state" != STOPPED ]]; then
        if [[ "$force" == --force ]]; then
            echo "ERROR: $container is $state, not STOPPED; refusing to touch its data." >&2
        else
            echo "ERROR: $container is $state, not STOPPED." >&2
        fi
        return 1
    fi
}

_validate_snapshot_name() {
    local name="$1"
    if [[ ! "$name" =~ ^[A-Za-z0-9][A-Za-z0-9_.-]*$ ]]; then
        echo "ERROR: snapshot names may contain only letters, digits, '.', '_' and '-'" >&2
        exit 1
    fi
}

# Creation-ordered records as: epoch<TAB>name. Snapshot directory mtimes are
# touched only after a successful copy, so they are reliable ordering metadata.
_snapshot_records() {
    local container="$1" snapshots
    snapshots=$(_data_snapshots "$container")
    [[ -d "$snapshots" ]] || return 0
    find "$snapshots" -mindepth 1 -maxdepth 1 -type d ! -name '.*' -printf '%T@\t%f\n' | sort -n
}

_snapshot_count() {
    local container="$1" count
    count=$(_snapshot_records "$container" | wc -l | tr -d ' ')
    echo "${count:-0}"
}

_slot_recovery_artifact() {
    local container="$1" current snapshots artifact
    current=$(_data_current "$container")
    snapshots=$(_data_snapshots "$container")
    artifact=$(find "$(dirname "$current")" -maxdepth 1 -type d \
        -name 'current.restore-*' -print -quit 2>/dev/null || true)
    if [[ -z "$artifact" ]]; then
        artifact=$(find "$snapshots" -maxdepth 1 -type d \
            \( -name '.*.tmp.*' -o -name '.*.replaced.*' -o -name '.restore-prune.*' \) \
            -print -quit 2>/dev/null || true)
    fi
    if [[ -n "$artifact" ]]; then
        echo "$artifact"
    fi
}

_snapshot() {
    local container="$1" name="$2" force="${3:-}"
    local current snapshots target tmp replaced result=0 cleanup_result=0
    local target_existed=0 snapshot_committed=0
    _require_data_store
    _validate_snapshot_name "$name"
    current=$(_data_current "$container")
    snapshots=$(_data_snapshots "$container")
    target="$snapshots/$name"
    tmp="$snapshots/.${name}.tmp.$$"
    replaced="$snapshots/.${name}.replaced.$$"

    local recovery_artifact
    recovery_artifact=$(_slot_recovery_artifact "$container")
    if [[ -n "$recovery_artifact" ]]; then
        echo "ERROR: unresolved snapshot/restore recovery data exists at $recovery_artifact" >&2
        return 1
    fi

    _snapshot_signal_cleanup() {
        local cleanup_status=0 restore_errexit=0
        [[ $- == *e* ]] && restore_errexit=1
        set +e
        rm -rf -- "$tmp"
        if (( snapshot_committed == 0 )); then
            if (( target_existed == 1 )) && [[ -e "$replaced" ]]; then
                if [[ -e "$target" ]]; then
                    rm -rf -- "$target" || cleanup_status=$?
                fi
                if [[ ! -e "$target" ]]; then
                    mv "$replaced" "$target" || cleanup_status=$?
                fi
            elif (( target_existed == 0 )) && [[ -e "$target" ]]; then
                rm -rf -- "$target" || cleanup_status=$?
            fi
        elif [[ -e "$replaced" ]]; then
            rm -rf -- "$replaced" || cleanup_status=$?
        fi

        if [[ "$(_state "$container")" == RUNNING ]]; then
            if ! incus exec "$container" -- systemctl is-active --quiet postgresql@17-main; then
                incus exec "$container" -- systemctl start postgresql@17-main \
                    && _pg_wait_ready "$container" || cleanup_status=$?
            fi
        else
            cleanup_status=1
        fi
        if (( cleanup_status != 0 )); then
            echo "ERROR: snapshot cleanup was incomplete; inspect $target and $replaced." >&2
        fi
        (( restore_errexit == 1 )) && set -e
        return "$cleanup_status"
    }

    mkdir -p "$current" "$snapshots"
    if [[ -e "$target" && "$force" != "--force" ]]; then
        echo "ERROR: snapshot '$name' already exists on $container (pass --force to the script, or force=1 via make, to replace it)." >&2
        exit 1
    fi
    [[ -e "$target" ]] && target_existed=1
    if [[ "$(_state "$container")" != RUNNING ]] \
        || ! incus exec "$container" -- systemctl is-active --quiet postgresql@17-main; then
        echo "ERROR: $container and PostgreSQL must be running before taking a snapshot." >&2
        return 1
    fi
    SIGNAL_CLEANUP=_snapshot_signal_cleanup

    # Stop PostgreSQL cleanly, then make a same-filesystem XFS CoW clone. This
    # is effectively instant and consumes blocks only as current/snapshot data
    # diverge, unlike Incus's stock-kernel `dir` snapshots.
    rm -rf -- "$tmp" "$replaced"
    mkdir "$tmp"
    if incus exec "$container" -- systemctl stop postgresql@17-main; then
        :
    else
        result=$?
    fi
    if (( result == 0 )) \
        && cp -a --reflink=always --sparse=auto "$current/." "$tmp/" \
        && touch "$tmp"; then
        if [[ -e "$target" ]]; then
            if mv "$target" "$replaced" && mv "$tmp" "$target"; then
                result=0
            else
                result=$?
                [[ -e "$target" ]] || mv "$replaced" "$target" 2>/dev/null || true
            fi
        elif mv "$tmp" "$target"; then
            result=0
        else
            result=$?
        fi
    else
        result=$?
    fi
    if (( result != 0 )); then
        _snapshot_signal_cleanup || cleanup_result=$?
        SIGNAL_CLEANUP=
        unset -f _snapshot_signal_cleanup
        echo "ERROR: failed to create reflink snapshot '$name' on $container." >&2
        (( cleanup_result == 0 )) || echo "ERROR: automatic snapshot rollback was incomplete." >&2
        return "$result"
    fi

    if incus exec "$container" -- systemctl start postgresql@17-main \
        && _pg_wait_ready "$container"; then
        snapshot_committed=1
    else
        result=$?
        _snapshot_signal_cleanup || cleanup_result=$?
        SIGNAL_CLEANUP=
        unset -f _snapshot_signal_cleanup
        echo "ERROR: PostgreSQL did not restart cleanly; the previous named snapshot was restored." >&2
        (( cleanup_result == 0 )) || echo "ERROR: automatic snapshot rollback was incomplete." >&2
        return "$result"
    fi

    rm -rf -- "$tmp" "$replaced"
    SIGNAL_CLEANUP=
    unset -f _snapshot_signal_cleanup
    echo "Snapshot '$name' created on $container."
}

_restore() {
    local container="$1" name="$2" force="${3:-}"
    local current snapshots target after reply new old failed prune snap
    local result=0 cleanup_result=0 container_was_running=0 restore_committed=0
    _require_data_store
    _validate_snapshot_name "$name"
    current=$(_data_current "$container")
    snapshots=$(_data_snapshots "$container")
    target="$snapshots/$name"
    new="${current}.restore-new.$$"
    old="${current}.restore-old.$$"
    failed="${current}.restore-failed.$$"
    prune="$snapshots/.restore-prune.$$"

    local recovery_artifact
    recovery_artifact=$(_slot_recovery_artifact "$container")
    if [[ -n "$recovery_artifact" ]]; then
        echo "ERROR: unresolved snapshot/restore recovery data exists at $recovery_artifact" >&2
        return 1
    fi

    _restore_signal_cleanup() {
        local cleanup_status=0 restore_errexit=0 candidate_moved=0
        [[ $- == *e* ]] && restore_errexit=1
        set +e
        rm -rf -- "$new" || cleanup_status=$?

        if (( restore_committed == 0 )); then
            if [[ -d "$old" ]]; then
                if [[ "$(_state "$container")" != STOPPED ]]; then
                    _stop_checked "$container" --force || cleanup_status=$?
                fi
                if [[ "$(_state "$container")" == STOPPED ]]; then
                    if [[ -e "$current" ]]; then
                        if mv "$current" "$failed"; then
                            candidate_moved=1
                        else
                            cleanup_status=$?
                        fi
                    fi
                    if [[ ! -e "$current" ]]; then
                        if mv "$old" "$current"; then
                            if (( candidate_moved == 1 )); then
                                rm -rf -- "$failed" || cleanup_status=$?
                            fi
                        else
                            cleanup_status=$?
                            if (( candidate_moved == 1 )) && [[ ! -e "$current" ]]; then
                                mv "$failed" "$current" || cleanup_status=$?
                            fi
                        fi
                    fi
                else
                    cleanup_status=1
                fi
            fi

            if [[ -d "$prune" ]]; then
                for snap in "$prune"/*; do
                    [[ -e "$snap" ]] || continue
                    if [[ -e "$snapshots/$(basename "$snap")" ]]; then
                        cleanup_status=1
                        continue
                    fi
                    mv "$snap" "$snapshots/$(basename "$snap")" || cleanup_status=$?
                done
                if find "$prune" -mindepth 1 -print -quit | grep -q .; then
                    cleanup_status=1
                else
                    rmdir "$prune" || cleanup_status=$?
                fi
            fi

            if (( container_was_running == 1 )); then
                if [[ "$(_state "$container")" != RUNNING ]]; then
                    incus start "$container" || cleanup_status=$?
                fi
                if [[ "$(_state "$container")" == RUNNING ]]; then
                    _pg_wait_ready "$container" || cleanup_status=$?
                fi
            fi
        else
            rm -rf -- "$old" "$failed" "$prune" || cleanup_status=$?
        fi

        if (( cleanup_status != 0 )); then
            echo "ERROR: restore cleanup was incomplete; preserved recovery paths:" >&2
            echo "       $current" >&2
            echo "       $old" >&2
            echo "       $failed" >&2
            echo "       $prune" >&2
        fi
        (( restore_errexit == 1 )) && set -e
        return "$cleanup_status"
    }

    if [[ ! -d "$target" ]]; then
        echo "ERROR: snapshot '$name' does not exist on $container." >&2
        exit 1
    fi

    # Preserve the original timeline semantics: restoring an older checkpoint
    # discards every later one after confirmation, even though XFS itself does
    # not impose ZFS's rollback restriction.
    after=$(_snapshot_records "$container" \
        | awk -F '\t' -v target="$name" '$2 == target { seen=1; next } seen { print $2 }')
    if [[ -n "$after" ]]; then
        echo "==> Snapshots on $container that will be deleted:"
        echo "$after" | sed 's/^/     /'
        if [[ "$force" == --force ]]; then
            :
        elif [[ -t 0 ]]; then
            printf 'Continue? [Y/n] ' >&2
            read -r reply
            [[ "${reply:-Y}" =~ ^[Yy]$ ]] || { echo "Aborted."; exit 1; }
        else
            # The outer `container machine run --interactive` (non-TTY) transport
            # delivers EOF on stdin immediately, so a `read` here would just fail
            # instead of ever letting the user answer. Refuse instead of guessing.
            echo "ERROR: this confirmation cannot be answered through the non-TTY machine transport." >&2
            echo "       Re-run with force to skip the prompt and proceed, e.g.:" >&2
            echo "         make pg.restore name=$name force=1          (active slot)" >&2
            echo "         make pg.staging.restore name=$name force=1  (staging slot)" >&2
            echo "       (or pass --force directly to the script)." >&2
            exit 1
        fi
    fi

    [[ "$(_state "$container")" == RUNNING ]] && container_was_running=1
    SIGNAL_CLEANUP=_restore_signal_cleanup

    # Build the candidate while the current database is still serving. Both
    # paths are on the same XFS filesystem, so the final rename window is tiny.
    rm -rf -- "$new"
    mkdir "$new"
    if cp -a --reflink=always --sparse=auto "$target/." "$new/"; then
        result=0
    else
        result=$?
        _restore_signal_cleanup || cleanup_result=$?
        SIGNAL_CLEANUP=
        unset -f _restore_signal_cleanup
        echo "ERROR: failed to stage reflink snapshot '$name' on $container." >&2
        (( cleanup_result == 0 )) || echo "ERROR: automatic restore cleanup was incomplete." >&2
        return "$result"
    fi

    # From this point cleanup uses actual Incus state and path existence as the
    # transaction record, avoiding signal windows between a command and a flag
    # assignment. These names include this process ID and must not pre-exist.
    for snap in "$old" "$failed" "$prune"; do
        if [[ -e "$snap" ]]; then
            rm -rf -- "$new"
            echo "ERROR: refusing restore because recovery path '$snap' already exists." >&2
            return 1
        fi
    done
    if _stop_checked "$container"; then
        result=0
    else
        result=$?
        _restore_signal_cleanup || cleanup_result=$?
        SIGNAL_CLEANUP=
        unset -f _restore_signal_cleanup
        return "$result"
    fi

    # Repair networking before touching the data, so a configuration failure
    # cannot strand an otherwise intact current dataset.
    if case "$container" in
        "$BACKEND_A") _repair_backend_ip "$container" "$(_pick_backend_a_ip)" ;;
        "$BACKEND_B") _repair_backend_ip "$container" "$(_pick_backend_b_ip)" ;;
    esac; then
        result=0
    else
        result=$?
        _restore_signal_cleanup || cleanup_result=$?
        SIGNAL_CLEANUP=
        unset -f _restore_signal_cleanup
        echo "ERROR: failed to repair networking before restore; current data was not changed." >&2
        (( cleanup_result == 0 )) || echo "ERROR: automatic restore cleanup was incomplete." >&2
        return "$result"
    fi

    if mv "$current" "$old" && mv "$new" "$current"; then
        result=0
    else
        result=$?
    fi

    if (( result != 0 )); then
        _restore_signal_cleanup || cleanup_result=$?
        SIGNAL_CLEANUP=
        unset -f _restore_signal_cleanup
        echo "ERROR: failed to install reflink snapshot '$name' on $container." >&2
        (( cleanup_result == 0 )) || echo "ERROR: automatic restore rollback was incomplete." >&2
        return "$result"
    fi

    if incus start "$container" && _pg_wait_ready "$container"; then
        result=0
    else
        result=$?
        echo "ERROR: restored data did not start cleanly; rolling back to the pre-restore state..." >&2
        _restore_signal_cleanup || cleanup_result=$?
        SIGNAL_CLEANUP=
        unset -f _restore_signal_cleanup
        if (( cleanup_result != 0 )); then
            echo "ERROR: automatic restore rollback was incomplete." >&2
        fi
        return "$result"
    fi

    # Stage timeline pruning with reversible renames. The restore commits only
    # after PostgreSQL is healthy and every newer snapshot has moved aside.
    if mkdir "$prune"; then
        :
    else
        result=$?
    fi
    if (( result == 0 )) && [[ -n "$after" ]]; then
        while IFS= read -r snap; do
            if mv "$snapshots/$snap" "$prune/$snap"; then
                :
            else
                result=$?
                break
            fi
        done <<< "$after"
    fi
    if (( result != 0 )); then
        echo "ERROR: failed to stage timeline pruning; rolling back the restore..." >&2
        _restore_signal_cleanup || cleanup_result=$?
        SIGNAL_CLEANUP=
        unset -f _restore_signal_cleanup
        (( cleanup_result == 0 )) || echo "ERROR: automatic restore rollback was incomplete." >&2
        return "$result"
    fi

    # Commit only after PostgreSQL and the complete timeline transition proved
    # healthy. From here the restored state is authoritative.
    restore_committed=1
    if rm -rf -- "$old" "$failed" "$prune"; then
        result=0
    else
        result=$?
    fi
    SIGNAL_CLEANUP=
    unset -f _restore_signal_cleanup
    if (( result != 0 )); then
        echo "ERROR: restore committed, but temporary rollback data could not be removed." >&2
        return "$result"
    fi
    echo "Restored $container to snapshot '$name'."
}

_restore_last() {
    local container="$1" force="${2:-}"
    local name
    name=$(_snapshot_records "$container" | tail -n1 | cut -f2-)
    if [[ -z "$name" ]]; then
        echo "No snapshots on $container."
        exit 1
    fi
    echo "==> Restoring $container to most recent snapshot: $name"
    _restore "$container" "$name" "$force"
}

# active slot
cmd_snapshot() {
    local name="${1:?Usage: snapshot <name> [--force]}"; shift || true
    _snapshot "$(_c_active)" "$name" "${1:-}"
}
cmd_restore() {
    local name="${1:?Usage: restore <name> [--force]}"; shift || true
    _restore "$(_c_active)" "$name" "${1:-}"
}
cmd_restore_last() { _restore_last "$(_c_active)" "${1:-}"; }

# List snapshots for a container, or note it isn't provisioned yet. Keeps
# `make status` (which calls this) from failing on a fresh host before pg.up.
_snapshot_list() {
    if incus info "$1" >/dev/null 2>&1; then
        local records epoch name created
        if ! _data_store_mounted; then
            echo "(data store not mounted — run 'make machine')"
            return
        fi
        records=$(_snapshot_records "$1")
        if [[ -z "$records" ]]; then
            echo "(no snapshots)"
            return
        fi
        printf '%-36s %s\n' NAME CREATED_AT
        while IFS=$'\t' read -r epoch name; do
            created=$(date --date="@${epoch}" '+%Y-%m-%d %H:%M:%S %z')
            printf '%-36s %s\n' "$name" "$created"
        done <<< "$records"
    else
        echo "(not provisioned — run 'make pg.up')"
    fi
}

# Unified listing for both slots.
cmd_snapshots() {
    local with_psql="${1:-}" a s proxy_ip
    a=$(_active); s=$(_staging)
    if [[ "$with_psql" == --with-psql ]]; then
        proxy_ip=$(_proxy_ip)
    fi
    echo "─── active  (${BACKEND_PREFIX}-${a}) ───"
    if [[ "$with_psql" == --with-psql ]]; then
        _print_psql_command "$ " "$proxy_ip" "$ACTIVE_PORT"
        echo
    fi
    _snapshot_list "${BACKEND_PREFIX}-${a}"
    echo
    echo "─── staging (${BACKEND_PREFIX}-${s}) ───"
    if [[ "$with_psql" == --with-psql ]]; then
        _print_psql_command "$ " "$proxy_ip" "$STAGING_PORT"
        echo
    fi
    _snapshot_list "${BACKEND_PREFIX}-${s}"
}

# staging slot
cmd_staging_snapshot() {
    local name="${1:?Usage: staging.snapshot <name> [--force]}"; shift || true
    _snapshot "$(_c_staging)" "$name" "${1:-}"
}
cmd_staging_restore() {
    local name="${1:?Usage: staging.restore <name> [--force]}"; shift || true
    _restore "$(_c_staging)" "$name" "${1:-}"
}
cmd_staging_restore_last() { _restore_last "$(_c_staging)" "${1:-}"; }
cmd_staging_reset()        { _restore "$(_c_staging)" initial; }
cmd_staging_stop()         { incus stop "$(_c_staging)"; }
cmd_staging_start()        { incus start "$(_c_staging)"; }

# Shell / psql / ip / logs, per slot.
_psql() {
    local container="$1"; shift
    incus exec "$container" -- env PGPASSWORD="$PG_PASSWORD" \
        psql -U "$PG_USER" "$PG_DB" "$@"
}
cmd_psql()         { _psql "$(_c_active)"  "$@"; }
cmd_staging_psql() { _psql "$(_c_staging)" "$@"; }

cmd_shell()         { incus exec "$(_c_active)"  -- bash; }
cmd_staging_shell() { incus exec "$(_c_staging)" -- bash; }

# IPv4 when running; otherwise the lifecycle state (STOPPED, FROZEN, …).
_ip_or_state() {
    local container="$1" ip
    ip=$(_container_ip "$container")
    if [[ -n "$ip" ]]; then
        echo "$ip"
    else
        echo "$(_state "$container")"
    fi
}

# Unified port + backend view for both slots. The proxy endpoint (proxy-ip:port)
# is the client-facing fact; the backend column shows its container IP when
# running, or its state (STOPPED, …) when not.
cmd_ip() {
    local a s info_a info_s proxy_ip endpoint_a endpoint_s pstate
    a=$(_active); s=$(_staging)
    info_a=$(_ip_or_state "${BACKEND_PREFIX}-${a}")
    info_s=$(_ip_or_state "${BACKEND_PREFIX}-${s}")
    proxy_ip=$(_proxy_ip)
    if [[ -n "$proxy_ip" ]]; then
        endpoint_a="${proxy_ip}:${ACTIVE_PORT}"
        endpoint_s="${proxy_ip}:${STAGING_PORT}"
    else
        pstate=$(_state "$PROXY")
        endpoint_a="$PROXY ${pstate:-none}"
        endpoint_s="$endpoint_a"
    fi
    printf '%-8s  %-22s  →  %-10s (%s)\n' \
        active  "$endpoint_a" "${BACKEND_PREFIX}-${a}" "$info_a"
    printf '%-8s  %-22s  →  %-10s (%s)\n' \
        staging "$endpoint_s" "${BACKEND_PREFIX}-${s}" "$info_s"
}

cmd_logs()         { incus exec "$(_c_active)"  -- tail -f /var/log/postgresql/postgresql-17-main.log; }
cmd_staging_logs() { incus exec "$(_c_staging)" -- tail -f /var/log/postgresql/postgresql-17-main.log; }

# Re-pin the backends' static IPs (self-heal a drifted lease), then re-point
# the proxy forwards from current state. Idempotent; run on every `make
# start` so the forwards survive an Apple machine reboot.
#
# Also recreates pg-proxy if it's missing but both backends exist (e.g. it
# was deleted by hand); the client-facing Apple machine endpoint does not
# change.
cmd_refresh() {
    if ! incus info "$PROXY" >/dev/null 2>&1 \
        && incus info "$BACKEND_A" >/dev/null 2>&1 \
        && incus info "$BACKEND_B" >/dev/null 2>&1; then
        echo "==> Recreating missing $PROXY..."
        _provision_proxy
    fi

    _repair_backend_ip "$BACKEND_A" "$(_pick_backend_a_ip)"
    _repair_backend_ip "$BACKEND_B" "$(_pick_backend_b_ip)"
    _set_forwards
    echo "Refreshed forwards (:$ACTIVE_PORT → active, :$STAGING_PORT → staging)."
}

# ---------------------------------------------------------------------------
# Full export / import (both slots + proxy + raw reflink-preserving XFS image)
# ---------------------------------------------------------------------------

cmd_export() {
    _require_data_store
    mkdir -p "$REPO_ROOT/var"
    local c tmp= partial= file base result=0 restart_result=0 mount_result=0 unmounted=0
    local was_a=0 was_b=0 was_proxy=0

    for c in "$BACKEND_A" "$BACKEND_B" "$PROXY"; do
        if ! incus info "$c" >/dev/null 2>&1; then
            echo "ERROR: cannot export: $c does not exist." >&2
            return 1
        fi
    done
    [[ "$(_state "$BACKEND_A")" == RUNNING ]] && was_a=1
    [[ "$(_state "$BACKEND_B")" == RUNNING ]] && was_b=1
    [[ "$(_state "$PROXY")" == RUNNING ]] && was_proxy=1

    tmp=$(mktemp -d /var/tmp/pg-dev-export.XXXXXX)
    partial=$(mktemp "$REPO_ROOT/var/.pg-dev-all-$(date +%Y-%m-%dT%H-%M-%S).XXXXXX.tar.gz")
    base=$(basename "$partial")
    file="$REPO_ROOT/var/${base#.}"
    printf '1\n' > "$tmp/format-version"
    _active > "$tmp/active-slot"

    _export_signal_cleanup() {
        set +e
        if ! mountpoint -q "$DATA_ROOT"; then
            if mount "$DATA_ROOT"; then
                unmounted=0
            fi
        fi
        if mountpoint -q "$DATA_ROOT"; then
            if (( was_a == 1 )) && [[ "$(_state "$BACKEND_A")" != RUNNING ]]; then
                incus start "$BACKEND_A" && _pg_wait_ready "$BACKEND_A"
            fi
            if (( was_b == 1 )) && [[ "$(_state "$BACKEND_B")" != RUNNING ]]; then
                incus start "$BACKEND_B" && _pg_wait_ready "$BACKEND_B"
            fi
            if (( was_proxy == 1 )) && [[ "$(_state "$PROXY")" != RUNNING ]]; then
                incus start "$PROXY"
            fi
            _set_forwards
        fi
        [[ -n "$tmp" ]] && rm -rf -- "$tmp"
        [[ -n "$partial" ]] && rm -f -- "$partial"
    }
    SIGNAL_CLEANUP=_export_signal_cleanup

    echo "==> Stopping pg-dev containers for a consistent full export..."
    for c in "$PROXY" "$BACKEND_A" "$BACKEND_B"; do
        if [[ "$(_state "$c")" != STOPPED ]]; then
            if _stop_checked "$c"; then
                :
            else
                result=$?
                break
            fi
        fi
    done

    if (( result == 0 )); then
        for c in "$BACKEND_A" "$BACKEND_B" "$PROXY"; do
            if incus export "$c" "$tmp/${c}.tar.gz"; then
                :
            else
                result=$?
                break
            fi
        done
    fi

    # Archive the unmounted sparse XFS image itself. This preserves all shared
    # reflink extents exactly instead of expanding every snapshot into a full
    # logical copy.
    if (( result == 0 )); then
        if umount "$DATA_ROOT"; then
            unmounted=1
        else
            result=$?
        fi
    fi
    if (( result == 0 )); then
        if tar --sparse -czf "$partial" \
            -C "$tmp" format-version active-slot \
                "${BACKEND_A}.tar.gz" "${BACKEND_B}.tar.gz" "${PROXY}.tar.gz" \
            -C "$(dirname "$DATA_IMAGE")" "$(basename "$DATA_IMAGE")"; then
            :
        else
            result=$?
        fi
    fi
    if (( unmounted == 1 )); then
        if mount "$DATA_ROOT"; then
            unmounted=0
        else
            mount_result=$?
            (( result != 0 )) || result=$mount_result
        fi
    fi

    if mountpoint -q "$DATA_ROOT"; then
        if (( was_a == 1 )) && [[ "$(_state "$BACKEND_A")" != RUNNING ]]; then
            incus start "$BACKEND_A" && _pg_wait_ready "$BACKEND_A" || restart_result=$?
        fi
        if (( was_b == 1 )) && [[ "$(_state "$BACKEND_B")" != RUNNING ]]; then
            incus start "$BACKEND_B" && _pg_wait_ready "$BACKEND_B" || restart_result=$?
        fi
        if (( was_proxy == 1 )) && [[ "$(_state "$PROXY")" != RUNNING ]]; then
            incus start "$PROXY" || restart_result=$?
        fi
        if (( restart_result == 0 )); then
            _set_forwards || restart_result=$?
        fi
    else
        restart_result=${mount_result:-1}
        (( restart_result != 0 )) || restart_result=1
        echo "ERROR: $DATA_ROOT is not mounted; PostgreSQL containers were left stopped." >&2
    fi

    rm -rf -- "$tmp"
    if (( result != 0 )); then
        rm -f -- "$partial"
        SIGNAL_CLEANUP=
        unset -f _export_signal_cleanup
        echo "ERROR: export failed." >&2
        return "$result"
    fi
    if mv "$partial" "$file"; then
        :
    else
        result=$?
        rm -f -- "$partial"
        SIGNAL_CLEANUP=
        unset -f _export_signal_cleanup
        echo "ERROR: failed to commit export archive '$file'." >&2
        return "$result"
    fi
    SIGNAL_CLEANUP=
    unset -f _export_signal_cleanup
    if [[ -n "${HOST_UID:-}" && -n "${HOST_GID:-}" ]]; then
        chown "$HOST_UID:$HOST_GID" "$STATE_DIR" "$file" 2>/dev/null || true
    fi
    echo "Exported both slots, timelines, and Incus containers to $file"
    if (( restart_result != 0 )); then
        echo "ERROR: export succeeded, but one or more containers did not restart cleanly." >&2
        return "$restart_result"
    fi
}

cmd_import_last() {
    _require_data_store
    local file tmp= new_image loop_device= image_type= imported_slot previous_slot result=0 cleanup_result=0
    local old_image= old_a= old_b= old_proxy= c stale_instance= stale_image= stale_data=
    local was_a=0 was_b=0 was_proxy=0
    local had_setup=0 existing_count=0
    local import_mutation_started=0
    local legacy
    file=$(ls -t "$REPO_ROOT/var/pg-dev-all-"*.tar.gz 2>/dev/null | head -1 || true)
    if [[ -z "$file" ]]; then
        legacy=$(ls -t "$REPO_ROOT/var/pg-dev-a-"*.tar.gz "$REPO_ROOT/var/pg-dev-b-"*.tar.gz \
            2>/dev/null | head -1 || true)
        if [[ -n "$legacy" ]]; then
            echo "No full Apple-machine export found in var/, but pre-port Colima-era" >&2
            echo "per-container exports exist (e.g. $legacy)." >&2
            echo "This version only imports the combined 'pg-dev-all-*.tar.gz' produced by" >&2
            echo "'$0 export'; it cannot import those legacy files. Import them manually with" >&2
            echo "'incus import <file>' if you still need that data." >&2
        else
            echo "No full Apple-machine export found in var/."
        fi
        exit 1
    fi
    echo "==> Importing from $file..."

    tmp=$(mktemp -d /var/lib/pg-dev-import.XXXXXX)
    _import_signal_cleanup() {
        local cleanup_status=0
        set +e
        if [[ -n "$loop_device" ]]; then
            if losetup --detach "$loop_device"; then
                loop_device=
            else
                cleanup_status=$?
            fi
        fi
        if (( import_mutation_started == 1 )) \
            && declare -F _rollback_import >/dev/null; then
            _rollback_import || cleanup_status=$?
        fi
        if (( cleanup_status == 0 )); then
            [[ -n "$tmp" ]] && rm -rf -- "$tmp"
        else
            echo "ERROR: import recovery data remains at $tmp" >&2
        fi
        return "$cleanup_status"
    }
    SIGNAL_CLEANUP=_import_signal_cleanup

    if ! tar --sparse -xzf "$file" -C "$tmp"; then
        rm -rf -- "$tmp"
        SIGNAL_CLEANUP=
        unset -f _import_signal_cleanup
        echo "ERROR: failed to extract '$file'; the running setup was not changed." >&2
        return 1
    fi
    new_image="$tmp/$(basename "$DATA_IMAGE")"
    imported_slot=$(tr -d '\n' < "$tmp/active-slot" 2>/dev/null || true)
    if [[ "$(tr -d '\n' < "$tmp/format-version" 2>/dev/null || true)" != 1 \
        || ! "$imported_slot" =~ ^[ab]$ \
        || ! -f "$new_image" \
        || ! -f "$tmp/${BACKEND_A}.tar.gz" \
        || ! -f "$tmp/${BACKEND_B}.tar.gz" \
        || ! -f "$tmp/${PROXY}.tar.gz" ]]; then
        rm -rf -- "$tmp"
        SIGNAL_CLEANUP=
        unset -f _import_signal_cleanup
        echo "ERROR: '$file' is not a complete pg-dev full export." >&2
        return 1
    fi

    if loop_device=$(losetup --find --show --read-only "$new_image"); then
        image_type=$(blkid --probe --output value --match-tag TYPE "$loop_device" 2>/dev/null || true)
        if [[ "$image_type" == xfs ]] && xfs_repair -n "$loop_device" >/dev/null; then
            result=0
        else
            result=$?
        fi
        if losetup --detach "$loop_device"; then
            loop_device=
        else
            result=$?
        fi
    else
        result=$?
    fi
    if (( result != 0 )) || [[ "$image_type" != xfs ]]; then
        if [[ -n "$loop_device" ]] && ! losetup --detach "$loop_device"; then
            SIGNAL_CLEANUP=
            unset -f _import_signal_cleanup
            echo "ERROR: could not detach validation loop device $loop_device; temporary data remains at $tmp." >&2
            return 1
        fi
        loop_device=
        rm -rf -- "$tmp"
        SIGNAL_CLEANUP=
        unset -f _import_signal_cleanup
        echo "ERROR: exported XFS image failed validation; the running setup was not changed." >&2
        return 1
    fi

    old_a="${BACKEND_A}-import-old-$$"
    old_b="${BACKEND_B}-import-old-$$"
    old_proxy="${PROXY}-import-old-$$"
    old_image="${DATA_IMAGE}.import-old.$$"
    previous_slot=$(_active)
    [[ "$(_state "$BACKEND_A")" == RUNNING ]] && was_a=1
    [[ "$(_state "$BACKEND_B")" == RUNNING ]] && was_b=1
    [[ "$(_state "$PROXY")" == RUNNING ]] && was_proxy=1

    # Uses Bash's dynamic scoping to access the state flags above. Every
    # destructive stage keeps its predecessor until this rollback is no longer
    # needed.
    _rollback_import() {
        local rollback_result=0 restore_errexit=0
        [[ $- == *e* ]] && restore_errexit=1
        set +e
        echo "==> Restoring the pre-import machine state..." >&2
        if (( had_setup == 0 )) || incus info "$old_proxy" >/dev/null 2>&1; then
            if incus info "$PROXY" >/dev/null 2>&1; then
                incus delete "$PROXY" --force || rollback_result=$?
            fi
        fi
        if (( had_setup == 0 )) || incus info "$old_a" >/dev/null 2>&1; then
            if incus info "$BACKEND_A" >/dev/null 2>&1; then
                incus delete "$BACKEND_A" --force || rollback_result=$?
            fi
        fi
        if (( had_setup == 0 )) || incus info "$old_b" >/dev/null 2>&1; then
            if incus info "$BACKEND_B" >/dev/null 2>&1; then
                incus delete "$BACKEND_B" --force || rollback_result=$?
            fi
        fi

        # old_image is the image-swap transaction record. It exists only after
        # the original image was safely unmounted and renamed.
        if (( rollback_result == 0 )) && [[ -e "$old_image" ]]; then
            if mountpoint -q "$DATA_ROOT"; then
                umount "$DATA_ROOT" || rollback_result=$?
            fi
            if (( rollback_result == 0 )) && [[ -e "$DATA_IMAGE" ]]; then
                mv "$DATA_IMAGE" "$tmp/failed-$(basename "$DATA_IMAGE")" \
                    || rollback_result=$?
            fi
            if (( rollback_result == 0 )); then
                mv "$old_image" "$DATA_IMAGE" || rollback_result=$?
            fi
            if (( rollback_result == 0 )); then
                mount "$DATA_ROOT" || rollback_result=$?
            fi
        elif (( rollback_result == 0 )) && ! mountpoint -q "$DATA_ROOT"; then
            # Unmount completed, but the original image rename did not.
            mount "$DATA_ROOT" || rollback_result=$?
        fi

        if incus info "$old_a" >/dev/null 2>&1; then
            incus move "$old_a" "$BACKEND_A" || rollback_result=$?
        fi
        if incus info "$old_b" >/dev/null 2>&1; then
            incus move "$old_b" "$BACKEND_B" || rollback_result=$?
        fi
        if incus info "$old_proxy" >/dev/null 2>&1; then
            incus move "$old_proxy" "$PROXY" || rollback_result=$?
        fi
        _set_active "$previous_slot" || rollback_result=$?

        if (( rollback_result == 0 )) && mountpoint -q "$DATA_ROOT"; then
            if (( was_a == 1 )) && [[ "$(_state "$BACKEND_A")" != RUNNING ]]; then
                incus start "$BACKEND_A" && _pg_wait_ready "$BACKEND_A" || rollback_result=$?
            fi
            if (( was_b == 1 )) && [[ "$(_state "$BACKEND_B")" != RUNNING ]]; then
                incus start "$BACKEND_B" && _pg_wait_ready "$BACKEND_B" || rollback_result=$?
            fi
            if (( was_proxy == 1 )) && [[ "$(_state "$PROXY")" != RUNNING ]]; then
                incus start "$PROXY" || rollback_result=$?
            fi
            _set_forwards || rollback_result=$?
        fi
        if (( rollback_result != 0 )); then
            echo "ERROR: automatic import rollback was incomplete; preserved recovery state:" >&2
            echo "       $tmp" >&2
            echo "       $old_image" >&2
            echo "       $old_a  $old_b  $old_proxy" >&2
        fi
        (( restore_errexit == 1 )) && set -e
        return "$rollback_result"
    }

    for c in "$BACKEND_A" "$BACKEND_B" "$PROXY"; do
        incus info "$c" >/dev/null 2>&1 && existing_count=$((existing_count + 1))
    done
    if (( existing_count != 0 && existing_count != 3 )); then
        rm -rf -- "$tmp"
        SIGNAL_CLEANUP=
        unset -f _import_signal_cleanup
        unset -f _rollback_import
        echo "ERROR: cannot import safely over a partial setup ($existing_count of 3 containers exist)." >&2
        return 1
    fi
    if (( existing_count == 3 )); then
        had_setup=1
    fi

    stale_instance=$(incus list --format csv -c n 2>/dev/null \
        | awk '/-import-old-[0-9]+$/ { print; exit }')
    stale_image=$(find "$(dirname "$DATA_IMAGE")" -maxdepth 1 -type f \
        -name "$(basename "$DATA_IMAGE").import-old.*" -print -quit)
    if (( had_setup == 0 )); then
        stale_data=$(find "$DATA_ROOT/a" "$DATA_ROOT/b" -mindepth 1 \
            ! -path "$DATA_ROOT/a/current" ! -path "$DATA_ROOT/a/snapshots" \
            ! -path "$DATA_ROOT/b/current" ! -path "$DATA_ROOT/b/snapshots" \
            -print -quit 2>/dev/null || true)
    fi
    if [[ -n "$stale_instance" || -n "$stale_image" || -n "$stale_data" ]]; then
        rm -rf -- "$tmp"
        SIGNAL_CLEANUP=
        unset -f _import_signal_cleanup
        unset -f _rollback_import
        echo "ERROR: stale import recovery state or unowned PostgreSQL data exists; refusing to overwrite it." >&2
        [[ -n "$stale_instance" ]] && echo "       instance: $stale_instance" >&2
        [[ -n "$stale_image" ]] && echo "       image:    $stale_image" >&2
        [[ -n "$stale_data" ]] && echo "       data:     $stale_data" >&2
        return 1
    fi

    import_mutation_started=1
    if (( had_setup == 1 )); then
        for c in "$BACKEND_A" "$BACKEND_B" "$PROXY"; do
            if _stop_checked "$c"; then :; else result=$?; break; fi
        done
    fi
    if (( result != 0 )); then
        if _rollback_import; then
            cleanup_result=0
        else
            cleanup_result=$?
        fi
        import_mutation_started=0
        (( cleanup_result == 0 )) && rm -rf -- "$tmp"
        SIGNAL_CLEANUP=
        unset -f _import_signal_cleanup
        unset -f _rollback_import
        return "$result"
    fi

    # Keep the old instances under temporary names until the imported pair has
    # booted and both PostgreSQL servers pass readiness checks.
    if (( had_setup == 1 )); then
        if incus move "$BACKEND_A" "$old_a"; then :; else result=$?; fi
    fi
    if (( result == 0 && had_setup == 1 )); then
        if incus move "$BACKEND_B" "$old_b"; then :; else result=$?; fi
    fi
    if (( result == 0 && had_setup == 1 )); then
        if incus move "$PROXY" "$old_proxy"; then :; else result=$?; fi
    fi
    if (( result == 0 )); then
        if umount "$DATA_ROOT"; then :; else result=$?; fi
    fi
    if (( result == 0 )); then
        if mv "$DATA_IMAGE" "$old_image"; then :; else result=$?; fi
    fi
    if (( result == 0 )); then
        if mv "$new_image" "$DATA_IMAGE"; then :; else result=$?; fi
    fi
    if (( result == 0 )); then
        if mount "$DATA_ROOT"; then :; else result=$?; fi
    fi
    if (( result == 0 )) && [[ ! -d "$DATA_ROOT/a/current" || ! -d "$DATA_ROOT/a/snapshots" \
        || ! -d "$DATA_ROOT/b/current" || ! -d "$DATA_ROOT/b/snapshots" ]]; then
        echo "ERROR: imported XFS image is missing one or more slot directories." >&2
        result=1
    fi

    if (( result == 0 )); then if incus import "$tmp/${BACKEND_A}.tar.gz"; then :; else result=$?; fi; fi
    if (( result == 0 )); then if incus import "$tmp/${BACKEND_B}.tar.gz"; then :; else result=$?; fi; fi
    if (( result == 0 )); then if incus import "$tmp/${PROXY}.tar.gz"; then :; else result=$?; fi; fi
    if (( result == 0 )); then if _repair_backend_ip "$BACKEND_A" "$(_pick_backend_a_ip)"; then :; else result=$?; fi; fi
    if (( result == 0 )); then if _repair_backend_ip "$BACKEND_B" "$(_pick_backend_b_ip)"; then :; else result=$?; fi; fi
    if (( result == 0 )); then if _set_active "$imported_slot"; then :; else result=$?; fi; fi
    if (( result == 0 )); then if incus start "$BACKEND_A" && _pg_wait_ready "$BACKEND_A"; then :; else result=$?; fi; fi
    if (( result == 0 )); then if incus start "$BACKEND_B" && _pg_wait_ready "$BACKEND_B"; then :; else result=$?; fi; fi
    if (( result == 0 )); then if incus start "$PROXY"; then :; else result=$?; fi; fi
    if (( result == 0 )); then if _set_forwards; then :; else result=$?; fi; fi

    if (( result != 0 )); then
        echo "ERROR: import failed; rolling back the previous machine state..." >&2
        if _rollback_import; then
            cleanup_result=0
        else
            cleanup_result=$?
        fi
        import_mutation_started=0
        (( cleanup_result == 0 )) && rm -rf -- "$tmp"
        SIGNAL_CLEANUP=
        unset -f _import_signal_cleanup
        unset -f _rollback_import
        if (( cleanup_result != 0 )); then
            echo "ERROR: recovery data remains at $tmp" >&2
        fi
        return "$result"
    fi

    # The imported setup is now healthy and forwarding both role ports. Make
    # it authoritative before deleting the rollback copies; an interrupt from
    # here onward leaves the new setup intact and, at worst, old remnants for
    # a later manual cleanup.
    import_mutation_started=0
    SIGNAL_CLEANUP=
    unset -f _import_signal_cleanup
    if (( had_setup == 1 )); then
        incus delete "$old_proxy" --force || cleanup_result=$?
        incus delete "$old_a" --force || cleanup_result=$?
        incus delete "$old_b" --force || cleanup_result=$?
    fi
    rm -f -- "$old_image" || cleanup_result=$?
    rm -rf -- "$tmp" || cleanup_result=$?
    unset -f _rollback_import
    if (( cleanup_result != 0 )); then
        echo "ERROR: import committed, but one or more rollback copies could not be removed." >&2
        return "$cleanup_result"
    fi
    echo "Imported and started both PostgreSQL slots and their snapshot timelines."
}

# ---------------------------------------------------------------------------
# Dispatcher
# ---------------------------------------------------------------------------

usage() {
    cat <<EOF
Usage: $(basename "$0") <command> [args]

Lifecycle:
  up                              provision pg-dev-a, pg-dev-b, pg-proxy
  down                            delete containers and both XFS data trees
  status                          show pointer + container states
  endpoint                        print endpoints, .pgpass, and psql commands
  promote                         flip active↔staging (re-point both forwards)
  refresh                         re-pin backend IPs + re-assert proxy forwards

Both slots (rendered side by side):
  ip                              proxy endpoint → backend, for both slots
  snapshots                       snapshot lists for active and staging

Active slot (whatever is currently active):
  psql [args]                     psql via incus exec into active backend
  shell                           bash into active backend
  logs                            tail postgres logs on active backend
  snapshot <name> [--force]       create an XFS reflink snapshot on active backend
  restore <name> [--force]        restore active backend to a snapshot
  restore-last [--force]          restore active backend to its most recent snapshot

Staging slot (the other one):
  staging.psql [args]
  staging.shell
  staging.logs
  staging.snapshot <name> [--force]
  staging.restore <name> [--force]
  staging.restore-last [--force]
  staging.reset                   shortcut: restore staging to 'initial'
  staging.stop                    stop staging backend
  staging.start                   start staging backend

Export / import (full setup):
  export                          export both slots, timelines, and proxy
  import-last                     restore the most recent full export
EOF
}

case "${1:-}" in
    up|down|promote|refresh|snapshot|restore|restore-last|\
    staging.snapshot|staging.restore|staging.restore-last|staging.reset|\
    staging.stop|staging.start|export|import-last)
        _acquire_mutation_lock
        ;;
esac

case "${1:-}" in
    up)             shift; cmd_up "$@" ;;
    down)           shift; cmd_down "$@" ;;
    status)         shift; cmd_status "$@" ;;
    endpoint)       shift; cmd_endpoint "$@" ;;
    promote)        shift; cmd_promote "$@" ;;
    refresh)        shift; cmd_refresh "$@" ;;

    psql)           shift; cmd_psql "$@" ;;
    shell)          shift; cmd_shell "$@" ;;
    ip)             shift; cmd_ip "$@" ;;
    logs)           shift; cmd_logs "$@" ;;
    snapshot)       shift; cmd_snapshot "$@" ;;
    restore)        shift; cmd_restore "$@" ;;
    restore-last)   shift; cmd_restore_last "$@" ;;
    snapshots)      shift; cmd_snapshots "$@" ;;

    staging.psql)         shift; cmd_staging_psql "$@" ;;
    staging.shell)        shift; cmd_staging_shell "$@" ;;
    staging.logs)         shift; cmd_staging_logs "$@" ;;
    staging.snapshot)     shift; cmd_staging_snapshot "$@" ;;
    staging.restore)      shift; cmd_staging_restore "$@" ;;
    staging.restore-last) shift; cmd_staging_restore_last "$@" ;;
    staging.reset)        shift; cmd_staging_reset "$@" ;;
    staging.stop)         shift; cmd_staging_stop "$@" ;;
    staging.start)        shift; cmd_staging_start "$@" ;;

    export)         shift; cmd_export "$@" ;;
    import-last)    shift; cmd_import_last "$@" ;;

    ""|-h|--help)   usage ;;
    *)              usage; exit 1 ;;
esac
